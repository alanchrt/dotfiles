#!/bin/bash
set -euo pipefail

# Read current deployed file (may be empty if file doesn't exist yet)
current=$(cat)
[ -z "$current" ] && current='{}'

managed=$(cat <<'MANAGED'
{
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Read(*)", "Glob(*)", "Grep(*)", "Edit", "Write", "WebFetch", "WebSearch"
    ],
    "ask": [
      "Bash(git reset --hard*)", "Bash(git push --force*)", "Bash(git push * --force*)",
      "Bash(git push -f *)", "Bash(git push * -f *)", "Bash(git clean -f*)",
      "Bash(git clean * -f*)", "Bash(git checkout -- *)", "Bash(git checkout .*)",
      "Bash(git restore .*)", "Bash(git stash drop*)", "Bash(git stash clear*)",
      "Bash(git branch -D*)", "Bash(sudo *)", "Bash(shutdown*)", "Bash(reboot*)",
      "Bash(poweroff*)", "Bash(halt*)", "Bash(mkfs*)", "Bash(dd *)",
      "Bash(crontab -r*)", "Bash(truncate *)"
    ],
    "deny": [
      "Read(~/.ssh/**)", "Read(~/.gnupg/**)", "Read(~/.gpg/**)", "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)", "Read(~/.kube/**)", "Read(**/.env)", "Read(**/.env.*)",
      "Read(**/credentials*)", "Read(**/secret*)", "Read(**/*.pem)", "Read(**/*.key)",
      "Read(~/.mozilla/**)", "Read(~/.config/google-chrome/**)", "Read(~/.config/chromium/**)",
      "Read(~/.config/BraveSoftware/**)", "Glob(~/.ssh/**)", "Glob(~/.gnupg/**)",
      "Glob(~/.aws/**)", "Glob(~/.mozilla/**)", "Glob(~/.config/google-chrome/**)",
      "Glob(~/.config/chromium/**)", "Glob(~/.config/BraveSoftware/**)",
      "Grep(~/.ssh/**)", "Grep(~/.gnupg/**)", "Grep(~/.aws/**)", "Grep(~/.mozilla/**)",
      "Grep(~/.config/google-chrome/**)", "Grep(~/.config/chromium/**)",
      "Grep(~/.config/BraveSoftware/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": "~/.claude/hooks/block-prod-writes.sh"},
          {"type": "command", "command": "~/.claude/hooks/block-sensitive-paths.sh"}
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {"type": "command", "command": "~/.claude/hooks/auto-format.sh"}
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {"type": "command", "command": "~/.claude/hooks/notify-input.sh"}
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {"type": "command", "command": "echo 'CONTEXT REMINDER: Edit chezmoi source files (dot_ prefix in repo), not deployed files. Use worktrees for non-trivial work on main. Ask before committing to main. Worktree remote push: git push -u origin worktree-NAME:refs/heads/{prefix}/hyphenated-name (fix/chore/docs/refactor prefix, default feat/). PR creation: gh pr create --draft. After PR merge: delete remote branch, then ExitWorktree action:remove.'"}
        ]
      }
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
MANAGED
)

printf '%s' "$current" | jq --argjson m "$managed" '. + {permissions: $m.permissions, hooks: $m.hooks, env: $m.env}'
