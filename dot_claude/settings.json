{
  "permissions": {
    "allow": [
      "Read(//**)",
      "Glob(//**)",
      "Grep(//**)",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "Bash(*)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.gpg/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.kube/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials*)",
      "Read(**/secret*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(~/.mozilla/**)",
      "Read(~/.config/google-chrome/**)",
      "Read(~/.config/chromium/**)",
      "Read(~/.config/BraveSoftware/**)",
      "Glob(~/.ssh/**)",
      "Glob(~/.gnupg/**)",
      "Glob(~/.aws/**)",
      "Glob(~/.mozilla/**)",
      "Glob(~/.config/google-chrome/**)",
      "Glob(~/.config/chromium/**)",
      "Glob(~/.config/BraveSoftware/**)",
      "Grep(~/.ssh/**)",
      "Grep(~/.gnupg/**)",
      "Grep(~/.aws/**)",
      "Grep(~/.mozilla/**)",
      "Grep(~/.config/google-chrome/**)",
      "Grep(~/.config/chromium/**)",
      "Grep(~/.config/BraveSoftware/**)",
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git push -f *)",
      "Bash(git push * -f *)",
      "Bash(git clean -f*)",
      "Bash(git clean * -f*)",
      "Bash(git checkout -- *)",
      "Bash(git checkout .*)",
      "Bash(git restore .*)",
      "Bash(git stash drop*)",
      "Bash(git stash clear*)",
      "Bash(git branch -D*)",
      "Bash(sudo *)",
      "Bash(shutdown*)",
      "Bash(reboot*)",
      "Bash(poweroff*)",
      "Bash(halt*)",
      "Bash(mkfs*)",
      "Bash(dd *)",
      "Bash(crontab -r*)",
      "Bash(truncate *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-prod-writes.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-sensitive-paths.sh"
          }
        ]
      }
    ]
  }
}
