{
  "permissions": {
    "allow": [
      "Read(//**)",
      "Glob(//**)",
      "Grep(//**)",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(npm *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(make *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(jq *)",
      "Bash(curl *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(node *)",
      "Bash(go *)",
      "Bash(cargo *)",
      "Bash(rustc *)",
      "Bash(ansible-playbook *)",
      "Bash(chezmoi *)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.gpg/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.kube/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/credentials*)",
      "Read(**/secret*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(~/.mozilla/**)",
      "Read(~/.config/google-chrome/**)",
      "Read(~/.config/chromium/**)",
      "Read(~/.config/BraveSoftware/**)",
      "Glob(~/.ssh/**)",
      "Glob(~/.gnupg/**)",
      "Glob(~/.aws/**)",
      "Glob(~/.mozilla/**)",
      "Glob(~/.config/google-chrome/**)",
      "Glob(~/.config/chromium/**)",
      "Glob(~/.config/BraveSoftware/**)",
      "Grep(~/.ssh/**)",
      "Grep(~/.gnupg/**)",
      "Grep(~/.aws/**)",
      "Grep(~/.mozilla/**)",
      "Grep(~/.config/google-chrome/**)",
      "Grep(~/.config/chromium/**)",
      "Grep(~/.config/BraveSoftware/**)",
      "Bash(git reset --hard*)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git push -f *)",
      "Bash(git push * -f *)",
      "Bash(git clean -f*)",
      "Bash(git clean * -f*)",
      "Bash(git checkout -- *)",
      "Bash(git checkout .*)",
      "Bash(git restore .*)",
      "Bash(git stash drop*)",
      "Bash(git stash clear*)",
      "Bash(git branch -D*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-prod-writes.sh"
          }
        ]
      }
    ]
  }
}
