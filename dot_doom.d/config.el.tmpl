    (delete-other-windows)))

(defun my/wst-prune-unreadable-treemacs-projects ()
  "Remove unreadable persisted Treemacs projects before WST opens its tree."
  (when (and (require 'treemacs nil t)
             (fboundp 'treemacs-workspaces)
             (fboundp 'treemacs-workspace->projects)
             (fboundp 'treemacs-project->path)
             (fboundp 'treemacs-project->refresh-path-status!)
             (fboundp 'treemacs-project->is-unreadable?))
    (dolist (workspace (treemacs-workspaces))
      (setf (treemacs-workspace->projects workspace)
            (seq-remove
             (lambda (project)
               (treemacs-project->refresh-path-status! project)
               (treemacs-project->is-unreadable? project))
             (treemacs-workspace->projects workspace))))))

(defun my/wst-open-stream-pane (dir)
  "Open a stream-scoped Treemacs + Magit layout for DIR."
  (interactive "DStream directory: ")
  (my/wst-stop-stream-refresh)
  (my/wst-ensure-dirty-tree-tables)
  (let ((dir (file-name-as-directory (expand-file-name dir))))
    (set-frame-parameter nil 'my/wst-stream-pane t)
    (ignore-errors (my/wst-prune-unreadable-treemacs-projects))
    (my/wst-enable-stream-refresh dir)
    (add-hook 'treemacs-pre-file-insert-predicates
              #'my/wst-treemacs-hide-clean-path-p)
    (my/wst-delete-other-main-windows)
    (magit-status dir)
    (my/wst-enable-magit-status-refresh dir)
    (let ((magit-buffer (current-buffer)))
      (my/wst-show-treemacs-stream-project dir :reset)
      (when (fboundp 'treemacs-select-window)
        (treemacs-select-window))
      (when-let ((project (treemacs--find-project-for-path dir)))
        (if (my/wst-dirty-tree-has-files-p)
            (progn
              (my/wst-expand-treemacs-project project)
              (run-at-time 0.2 nil #'my/wst-expand-treemacs-project-for-dir dir)
              (run-at-time 1 nil #'my/wst-expand-treemacs-project-for-dir dir))
          (my/wst-collapse-treemacs-project project)))
      (when (get-buffer-window magit-buffer t)
        (select-window (get-buffer-window magit-buffer t)))
      (my/wst-refresh-treemacs-git-state)
      (switch-to-buffer magit-buffer))))

