;; ── vdiff-magit: side-by-side diffs ─────────────────────────────────────────
(use-package! vdiff-magit
  :after magit
  :config
  (setq vdiff-magit-stage-is-2way t)
  ;; vdiff--refresh-overlays and vdiff-refine-all-hunks both guard with
  ;; (vdiff--buffer-p) which reads the buffer-local vdiff--session. When called
  ;; from the async diff sentinel, current-buffer is the process buffer where
  ;; that local is nil, so both are silently skipped. Fix by wrapping the
  ;; entire vdiff--diff-refresh-finish (which calls both) in the right context.
  (advice-add 'vdiff--diff-refresh-finish :around
              (lambda (fn session &rest args)
                (if (vdiff--buffer-p)
                    (apply fn session args)
                  (when-let ((buf (car (vdiff-session-buffers session))))
                    (with-current-buffer buf
                      (apply fn session args)))))
              '((name . vdiff-fix-sentinel-context)))
  (setq vdiff-auto-refine t)
  ;; Fill missing/deleted-line regions with blank space instead of the default
  ;; row of dashes — cleaner, GitHub-like empty gutter.
  (setq vdiff-subtraction-fill-char ?\s)
  ;; vdiff paints "extra content" (present in one pane, absent in the other)
  ;; with vdiff-addition-face in BOTH panes, and modified lines with
  ;; vdiff-change-face in both panes — so in the old/left pane, both deletions
  ;; and the old side of a modification show green, indistinguishable from real
  ;; additions in the new pane. After each refresh, repaint the old pane's
  ;; addition AND change overlays amber, so the left/old side is always amber
  ;; (removed or replaced) and only the new pane shows green. The old pane is the
  ;; revision buffer (no live file); fall back to the session's first buffer.
  (defun my/vdiff-recolor-deletions (session &rest _)
    (when (vdiff-session-p session)
      (let* ((bufs (vdiff-session-buffers session))
             (a (car bufs)) (b (cadr bufs))
             (old (cond ((and (buffer-live-p a) (not (buffer-file-name a))) a)
                        ((and (buffer-live-p b) (not (buffer-file-name b))) b)
                        (t a))))
        (when (buffer-live-p old)
          (with-current-buffer old
            (dolist (ovr (overlays-in (point-min) (point-max)))
              (cond
               ;; Old-pane line region: a pure deletion ('addition type, painted
               ;; in both panes) OR the old side of a modification ('change).
               ;; Both are content being removed/replaced → amber, never green.
               ((memq (overlay-get ovr 'vdiff-type) '(addition change))
                (overlay-put ovr 'face 'my/vdiff-deletion-face))
               ;; Word-level refine in the old pane: refine-added (inside a
               ;; deletion) and refine-changed (old side of a modification) are
               ;; both green by default → amber emph.
               ((and (overlay-get ovr 'vdiff-refinement)
                     (memq (overlay-get ovr 'face)
                           '(vdiff-refine-added vdiff-refine-changed)))
                (overlay-put ovr 'face 'my/vdiff-deletion-refine-face)))))))))
  (advice-add 'vdiff--diff-refresh-finish :after #'my/vdiff-recolor-deletions)
  (define-key magit-mode-map "e" #'my/vdiff-magit-dwim)
  (define-key magit-mode-map "E" #'vdiff-magit-dispatch)
  (map! :map vdiff-mode-map
        :n "q"  #'vdiff-quit
        :n "za" #'vdiff-toggle-fold
        :n "zR" #'vdiff-open-all-folds
        :n "zM" #'vdiff-close-all-folds
        :n "R"  #'vdiff-refine-all-hunks
        :n "gf" nil))

(defun my/vdiff-magit-dwim ()
  "Open vdiff matching the diff Magit shows at point.

Mirrors Magit's own sections, so `e' shows the same hunks the cursor is on:
- Unstaged hunk/file -> index vs working tree (just the unstaged changes)
- Staged hunk/file   -> HEAD vs index (just the staged changes)
- Untracked file     -> HEAD vs working tree (the whole new file)
- Commit at point    -> that commit's diff

Unlike `vdiff-magit-show-working-tree' (HEAD vs working tree), this does not
conflate staged and unstaged changes when a file has both."
  (interactive)
  (cond
   ((magit-commit-at-point)
    (vdiff-magit-show-commit (magit-commit-at-point)))
   ((magit-file-at-point t)
    (let ((default-directory (magit-toplevel))
          (file (magit-file-at-point)))
      (pcase (magit-diff-type)
        ('unstaged (vdiff-magit-show-unstaged file))
        ('staged   (vdiff-magit-show-staged file))
        ;; untracked / undefined / committed-file fall back to the whole-file
        ;; diff (this is the prior behavior, so no regression on those paths).
        (_         (vdiff-magit-show-working-tree file)))))
   (t (user-error "Nothing to diff at point"))))

(defun my/treemacs-vdiff-at-point ()
  "Open a vdiff working-tree diff for the file at point in Treemacs."
  (interactive)
  (when-let* ((btn  (treemacs-current-button))
              (path (treemacs-button-get btn :path)))
    (when (file-regular-p path)
      (let* ((top (magit-toplevel (file-name-directory path)))
             (default-directory (or top (file-name-directory path)))
             ;; vdiff window management fails from a side window; pick a main window first
             (main-win (cl-find-if-not (lambda (w) (window-parameter w 'window-side))
                                       (window-list))))
        (when main-win (select-window main-win))
        (if top
            (vdiff-magit-show-working-tree (file-relative-name path top))
          (find-file path))))))

(after! treemacs
  ;; Treemacs uses a custom 'treemacs evil state; evil-define-key is required.
  (evil-define-key 'treemacs treemacs-mode-map
    (kbd "e") #'my/treemacs-vdiff-at-point))

;; ── Review markers: inline @agents comments addressed by /annotations ───────
;;
;; Workflow: `SPC r a' drops a `@agents <note>' comment on a line; review with
;; `SPC r n/p/s'; run /annotations in Claude Code to address each marker and
;; delete it as it goes; `SPC r x' clears any leftovers. A global pre-commit
;; hook blocks commits that still contain markers. The marker is built by
;; concatenation so the literal never appears in this committed file (the same
;; trick the pre-commit hook uses to avoid matching itself).
(defconst my/review-marker (concat "@agents" ":")
  "Inline review-marker prefix addressed by the /annotations command.")

(defun my/review--marker-line-p ()
  "Non-nil if the line at point contains the review marker."
  (save-excursion
    (beginning-of-line)
    (let ((case-fold-search nil))
      (search-forward my/review-marker (line-end-position) t))))

(defun my/review--marker-text ()
  "Return the note text of the marker on the current line, else nil."
  (save-excursion
    (beginning-of-line)
    (let ((case-fold-search nil))
      (when (search-forward my/review-marker (line-end-position) t)
        (let* ((raw (buffer-substring-no-properties (point) (line-end-position)))
               (ce  (string-trim (or comment-end "")))
               (s   (string-trim raw)))
          (when (and (> (length ce) 0) (string-suffix-p ce s))
            (setq s (string-trim (substring s 0 (- (length s) (length ce))))))
          s)))))

(defun my/review--insert-marker (indent text)
  "Insert a marker comment line for TEXT at point (point at line start)."
  (let* ((cs      (string-trim-right (or comment-start "#")))
         (ce      (string-trim (or comment-end "")))
         (comment (concat cs " " my/review-marker " " text
                          (unless (string-empty-p ce) (concat " " ce)))))
    (insert (make-string indent ?\s) comment "\n")))

(defun my/review-annotate-line ()
  "Add or edit a `@agents' review marker for the line at point.
If the current line or the line directly above already holds a marker, edit it
(the prompt is prefilled with its note; blank input deletes it). Otherwise
insert a new marker comment on a line above point."
  (interactive)
  (comment-normalize-vars)
  (let ((marker-bol
         (cond ((my/review--marker-line-p) (line-beginning-position))
               ((save-excursion (forward-line -1) (my/review--marker-line-p))
                (line-beginning-position 0)))))
    (if marker-bol
        (let* ((existing (save-excursion (goto-char marker-bol)
                                         (my/review--marker-text)))
               (indent   (save-excursion (goto-char marker-bol)
                                         (current-indentation)))
               (text     (read-string (concat my/review-marker " ") existing)))
          (save-excursion
            (goto-char marker-bol)
            (delete-region (line-beginning-position)
                           (min (point-max) (1+ (line-end-position))))
            (unless (string-blank-p text)
              (my/review--insert-marker indent text))))
      (let ((text   (read-string (concat my/review-marker " ")))
            (indent (current-indentation)))
        (unless (string-blank-p text)
          (save-excursion
            (beginning-of-line)
            (my/review--insert-marker indent text)))))))

(defun my/review-next-annotation ()
  "Move to the next `@agents' marker in the buffer (wraps)."
  (interactive)
  (let ((case-fold-search nil) (start (point)))
    (end-of-line)
    (if (or (re-search-forward (regexp-quote my/review-marker) nil t)
            (progn (goto-char (point-min))
                   (re-search-forward (regexp-quote my/review-marker) nil t)))
        (goto-char (match-beginning 0))
      (goto-char start)
      (user-error "No %s markers" my/review-marker))))

(defun my/review-previous-annotation ()
  "Move to the previous `@agents' marker in the buffer (wraps)."
  (interactive)
  (let ((case-fold-search nil) (start (point)))
    (beginning-of-line)
    (if (or (re-search-backward (regexp-quote my/review-marker) nil t)
            (progn (goto-char (point-max))
                   (re-search-backward (regexp-quote my/review-marker) nil t)))
        (goto-char (match-beginning 0))
      (goto-char start)
      (user-error "No %s markers" my/review-marker))))

(defun my/review-annotation-summary ()
  "List all `@agents' markers across the project."
  (interactive)
  (let ((dir (or (and (fboundp 'projectile-project-root)
                      (ignore-errors (projectile-project-root)))
                 (ignore-errors (vc-root-dir))
                 default-directory)))
    (if (fboundp 'consult-ripgrep)
        (consult-ripgrep dir my/review-marker)
      (occur (regexp-quote my/review-marker)))))

(defun my/review-clear-annotations ()
  "Delete every line containing a `@agents' marker across the project."
  (interactive)
  (let* ((root  (or (and (fboundp 'projectile-project-root)
                         (ignore-errors (projectile-project-root)))
                    (ignore-errors (vc-root-dir))
                    default-directory))
         (files (ignore-errors
                  (process-lines "rg" "-l" "--fixed-strings" "--"
                                 my/review-marker root))))
    (if (not files)
        (message "No %s markers found" my/review-marker)
      (when (yes-or-no-p (format "Remove %s lines from %d file(s)? "
                                 my/review-marker (length files)))
        (let ((n 0))
          (dolist (f files)
            (with-current-buffer (find-file-noselect f)
              (save-excursion
                (goto-char (point-min))
                (let ((case-fold-search nil))
                  (while (re-search-forward
                          (concat "^.*" (regexp-quote my/review-marker) ".*\n?")
                          nil t)
                    (replace-match "") (cl-incf n))))
              (save-buffer)))
          (message "Removed %d %s line(s) from %d file(s)"
                   n my/review-marker (length files)))))))

;; Shouty highlight so markers are impossible to miss. A custom font-lock
;; keyword (not hl-todo — its word-boundary regexp won't match the leading `@')
;; paints the marker and the rest of its line with a loud background. `prepend'
;; overrides the dim comment face; `:extend t' runs the bar to the window edge.
(defface my/review-marker-face '((t :inherit default))
  "Loud face for inline @agents review markers (colors set via custom-set-faces!).")
;; Set the colors with `custom-set-faces!' rather than baking them into the
;; `defface' spec: a plain `defface' is a no-op once the face already exists, so
;; editing it and running `doom/reload' won't update the live face until a full
;; restart. `custom-set-faces!' re-applies on every reload and after a theme loads.
;; Dracula pink background with Dracula's dark base as the text color (~7.4:1).
(custom-set-faces!
  '(my/review-marker-face :background "#ff79c6" :foreground "#282a36"
                          :weight bold :extend t))

(defun my/review-add-font-lock ()
  "Highlight `@agents' markers in the current buffer."
  (font-lock-add-keywords
   nil
   `((,(concat (regexp-quote my/review-marker) ".*$") 0 'my/review-marker-face prepend))
   'append)
  (when font-lock-mode (font-lock-flush)))

(dolist (hook '(prog-mode-hook text-mode-hook conf-mode-hook))
  (add-hook hook #'my/review-add-font-lock))

;; hl-line (the current-line highlight) is an overlay, so it paints over the
;; marker's text-property background: when the cursor sits on a marker line, the
;; pink is replaced by hl-line's dark background, leaving the dark marker text
;; unreadable. Suppress hl-line on marker lines (return a zero-width range) so the
;; pink + dark text keep their contrast in both states; other lines highlight as
;; usual.
(defun my/review-hl-line-range ()
  (if (save-excursion
        (beginning-of-line)
        (let ((case-fold-search nil))
          (search-forward my/review-marker (line-end-position) t)))
      (cons (point) (point))
    (cons (line-beginning-position) (line-beginning-position 2))))
(setq hl-line-range-function #'my/review-hl-line-range)

(map! :leader
      (:prefix ("r" . "review")
       :desc "Annotate line (@agents)" "a" #'my/review-annotate-line
       :desc "Next annotation"          "n" #'my/review-next-annotation
       :desc "Previous annotation"      "p" #'my/review-previous-annotation
       :desc "Annotation summary"       "s" #'my/review-annotation-summary
       :desc "Clear annotations"        "x" #'my/review-clear-annotations))
