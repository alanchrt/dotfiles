;;; $DOOMDIR/config.el -*- lexical-binding: t; -*-

;; Place your private configuration here! Remember, you do not need to run 'doom
;; sync' after modifying this file!

;; Always open maximized
(add-to-list 'default-frame-alist '(fullscreen . maximized))


;; Some functionality uses this to identify you, e.g. GPG configuration, email
;; clients, file templates and snippets. It is optional.
(setq user-full-name "{{ .name }}"
      user-mail-address "{{ .email }}")

;; Doom exposes five (optional) variables for controlling fonts in Doom:
;;
;; - `doom-font' -- the primary font to use
;; - `doom-variable-pitch-font' -- a non-monospace font (where applicable)
;; - `doom-big-font' -- used for `doom-big-font-mode'; use this for
;;   presentations or streaming.
;; - `doom-unicode-font' -- for unicode glyphs
;; - `doom-serif-font' -- for the `fixed-pitch-serif' face
;;
;; See 'C-h v doom-font' for documentation and more examples of what they
;; accept. For example:
;;
{{ if eq .chezmoi.os "darwin" -}}
(setq doom-font (font-spec :family "Hack Nerd Font" :size 14))
{{ else -}}
(setq doom-font (font-spec :family "Hack" :size 16))
{{ end -}}
;;
;; If you or Emacs can't find your font, use 'M-x describe-font' to look them
;; up, `M-x eval-region' to execute elisp code, and 'M-x doom/reload-font' to
;; refresh your font settings. If Emacs still can't find your font, it likely
;; wasn't installed correctly. Font issues are rarely Doom issues!

;; There are two ways to load a theme. Both assume the theme is installed and
;; available. You can either set `doom-theme' or manually load a theme with the
;; `load-theme' function. This is the default:
(setq doom-theme 'doom-dracula)

;; This determines the style of line numbers in effect. If set to `nil', line
;; numbers are disabled. For relative line numbers, set this to `relative'.
(setq display-line-numbers-type t)

;; Terminal Emacs frames (including WST tmux panes) don't get GUI clipboard
;; integration automatically, even though the daemon is running on the host.
;; Bridge kill/yank through the host clipboard tools when available.
(defun my/clipboard-command-p (command)
  (and command (executable-find command)))

(defun my/clipboard-copy-with (command text)
  (with-temp-buffer
    (insert text)
    (call-process-region (point-min) (point-max) command nil nil nil)))

(defun my/clipboard-paste-with (command)
  (with-temp-buffer
    (when (zerop (call-process command nil t nil))
      (buffer-string))))

(defun my/clipboard-copy (text)
  (cond
   ((my/clipboard-command-p "desktop-clipboard-copy")
    (my/clipboard-copy-with "desktop-clipboard-copy" text))
   ((my/clipboard-command-p "wl-copy")
    (my/clipboard-copy-with "wl-copy" text))
   ((my/clipboard-command-p "pbcopy")
    (my/clipboard-copy-with "pbcopy" text))
   ((my/clipboard-command-p "xclip")
    (with-temp-buffer
      (insert text)
      (call-process-region (point-min) (point-max) "xclip" nil nil nil
                           "-selection" "clipboard")))))

(defun my/clipboard-paste ()
  (cond
   ((my/clipboard-command-p "desktop-clipboard-paste")
    (my/clipboard-paste-with "desktop-clipboard-paste"))
   ((my/clipboard-command-p "wl-paste")
    (my/clipboard-paste-with "wl-paste"))
   ((my/clipboard-command-p "pbpaste")
    (my/clipboard-paste-with "pbpaste"))
   ((my/clipboard-command-p "xclip")
    (with-temp-buffer
      (when (zerop (call-process "xclip" nil t nil
                                 "-selection" "clipboard" "-out"))
        (buffer-string))))))

(setq select-enable-clipboard t
      save-interprogram-paste-before-kill t
      interprogram-cut-function #'my/clipboard-copy
      interprogram-paste-function #'my/clipboard-paste)

;; If you use `org' and don't want your org files in the default location below,
;; change `org-directory'. It must be set before org loads!
(setq org-directory "~/Documents/Notes")
(setq org-agenda-files (directory-files-recursively "~/Documents/Notes" "\\.org$"))

;; Whenever you reconfigure a package, make sure to wrap your config in an
;; `after!' block, otherwise Doom's defaults may override your settings. E.g.
;;
;;   (after! PACKAGE
;;     (setq x y))
;;
;; The exceptions to this rule:
;;
;;   - Setting file/directory variables (like `org-directory')
;;   - Setting variables which explicitly tell you to set them before their
;;     package is loaded (see 'C-h v VARIABLE' to look up their documentation).
;;   - Setting doom variables (which start with 'doom-' or '+').
;;
;; Here are some additional functions/macros that will help you configure Doom.
;;
;; - `load!' for loading external *.el files relative to this one
;; - `use-package!' for configuring packages
;; - `after!' for running code after a package has loaded
;; - `add-load-path!' for adding directories to the `load-path', relative to
;;   this file. Emacs searches the `load-path' when you load packages with
;;   `require' or `use-package'.
;; - `map!' for binding new keys
;;
;; To get information about any of these functions/macros, move the cursor over
;; the highlighted symbol at press 'K' (non-evil users must press 'C-c c k').
;; This will open documentation for it, including demos of how they are used.
;; Alternatively, use `C-h o' to look up a symbol (functions, variables, faces,
;; etc).
;;
;; You can also try 'gd' (or 'C-c c d') to jump to their definition and see how
;; they are implemented.

(map! :leader :desc "Autoformat" "t a" #'apheleia-mode)
(add-to-list 'safe-local-eval-forms '(apheleia-mode -1))

;; Use format-all formatter for javascript (prettier) and python (ruff)
(setq-hook! 'rjsx-mode-hook +format-with-lsp nil)
(setq-hook! 'typescript-mode-hook +format-with-lsp nil)
(setq-hook! 'typescript-ts-mode-hook +format-with-lsp nil)
(setq-hook! 'tsx-ts-mode-hook +format-with-lsp nil)
(setq-hook! 'js2-mode-hook +format-with-lsp nil)
(setq-hook! 'js-ts-mode-hook +format-with-lsp nil)
(setq-hook! 'python-mode-hook +format-with-lsp nil)
(setq-hook! 'python-ts-mode-hook +format-with-lsp nil)
(setq-hook! 'web-mode-hook +format-with-lsp nil)

;; Docker-compose file association
(add-to-list 'auto-mode-alist '("docker-compose[^/]*\\.ya?ml\\'" . yaml-mode))

;; Tailwind CSS LSP — runs as add-on alongside existing LSP servers
(use-package! lsp-tailwindcss
  :when (modulep! :tools lsp)
  :init
  (setq lsp-tailwindcss-add-on-mode t)
  :config
  (dolist (mode '(rjsx-mode typescript-mode typescript-tsx-mode tsx-ts-mode web-mode))
    (add-to-list 'lsp-tailwindcss-major-modes mode))
  (lsp-register-client
   (make-lsp-client
    :new-connection (lsp-stdio-connection '("tailwindcss-language-server" "--stdio"))
    :activation-fn #'lsp-tailwindcss--activate-p
    :server-id 'tailwindcss
    :priority -1
    :add-on? lsp-tailwindcss-add-on-mode
    :initialization-options #'lsp-tailwindcss--initialization-options)))

;; Enable fuzzy matching in vertico (orderless)
(after! orderless
  (setq orderless-matching-styles '(orderless-flex)))

;; Ruff formatter for Python (replaces black)
(after! python
  (set-formatter! 'ruff-format "ruff format -" :modes '(python-mode python-ts-mode)))

;; Live-refresh buffers when files change on disk (e.g. Claude Code edits).
;; Pair with `:ui vc-gutter` to get live fringe markers without manual revert.
(setq auto-revert-verbose nil
      auto-revert-use-notify t
      auto-revert-avoid-polling t
      auto-revert-interval 2
      auto-revert-stop-on-user-input nil)
(global-auto-revert-mode 1)

;; Show git state in Treemacs for both files and parent directories. Doom's
;; default is `simple', which only decorates file nodes.
(setq +treemacs-git-mode 'deferred)

(defun my/disable-line-numbers-in-special-buffer-h ()
  "Keep special tool buffers from briefly showing Doom line numbers."
  (setq-local display-line-numbers nil
              display-line-numbers-type nil)
  (when (bound-and-true-p display-line-numbers-mode)
    (display-line-numbers-mode -1)))

(after! treemacs
  (setq treemacs-silent-filewatch t
        treemacs-silent-refresh t
        treemacs-missing-project-action 'remove)
  (add-hook 'treemacs-mode-hook #'my/disable-line-numbers-in-special-buffer-h)
  (treemacs-filewatch-mode 1))

;; Keep Magit status useful as a passive worktree monitor. File buffers use
;; notifications above; only Magit status buffers opt back into timer checks.
(after! magit
  (setq magit-auto-revert-immediately t)
  (add-hook 'magit-mode-hook #'my/disable-line-numbers-in-special-buffer-h)
  (add-hook 'magit-post-refresh-hook #'my/disable-line-numbers-in-special-buffer-h)
  (add-hook 'window-selection-change-functions
            (defun my/disable-line-numbers-in-selected-magit-window-h (_frame)
              (when (derived-mode-p 'magit-mode)
                (my/disable-line-numbers-in-special-buffer-h))))
  (add-hook! 'magit-status-mode-hook
    (defun my/magit-status-auto-refresh-h ()
      (my/disable-line-numbers-in-special-buffer-h)
      (setq-local auto-revert-avoid-polling nil)
      (auto-revert-mode 1))))

(defun my/soften-ediff-faces-h ()
  "Use muted Dracula-tinted Ediff backgrounds without hiding font-lock colors."
  (dolist (spec '((ediff-current-diff-A . "#4a2f3a")
                  (ediff-current-diff-B . "#2d4a3a")
                  (ediff-current-diff-C . "#4a3f30")
                  (ediff-current-diff-Ancestor . "#403650")
                  (ediff-fine-diff-A . "#6b3345")
                  (ediff-fine-diff-B . "#336b4a")
                  (ediff-fine-diff-C . "#6b5733")
                  (ediff-fine-diff-Ancestor . "#51406b")
                  (ediff-even-diff-A . "#303241")
                  (ediff-even-diff-B . "#303241")
                  (ediff-even-diff-C . "#303241")
                  (ediff-even-diff-Ancestor . "#303241")
                  (ediff-odd-diff-A . "#282a36")
                  (ediff-odd-diff-B . "#282a36")
                  (ediff-odd-diff-C . "#282a36")
                  (ediff-odd-diff-Ancestor . "#282a36")))
    (when (facep (car spec))
      (set-face-attribute (car spec) nil
                          :background (cdr spec)
                          :foreground 'unspecified
                          :weight 'unspecified
                          :slant 'unspecified
                          :inverse-video nil
                          :extend t))))

(defun my/ediff-source-file-name ()
  "Return a file name Ediff can use for mode detection."
  (when-let* ((name (or buffer-file-name (buffer-name))))
    (replace-regexp-in-string "\\.~[^~]+~\\'" "" name)))

(defun my/ediff-set-source-mode (buffer)
  "Make Magit Ediff revision buffers use the source file's major mode."
  (when (buffer-live-p buffer)
    (with-current-buffer buffer
      (when-let* ((source-file-name (my/ediff-source-file-name)))
        (let ((buffer-file-name source-file-name))
          (set-auto-mode t)
          (when (bound-and-true-p font-lock-mode)
            (font-lock-ensure)))))))

(defun my/ediff-set-source-modes-h ()
  "Apply source major modes to all Ediff comparison buffers."
  (dolist (buffer (list (bound-and-true-p ediff-buffer-A)
                        (bound-and-true-p ediff-buffer-B)
                        (bound-and-true-p ediff-buffer-C)
                        (bound-and-true-p ediff-ancestor-buffer)))
    (my/ediff-set-source-mode buffer)))

(after! ediff
  (my/soften-ediff-faces-h)
  (add-hook 'doom-load-theme-hook #'my/soften-ediff-faces-h)
  (add-hook 'ediff-startup-hook #'my/ediff-set-source-modes-h))

(defvar-local my/wst-magit-refresh-timer nil)
(defvar-local my/wst-magit-refresh-state nil)
(defvar my/wst-stream-refresh-timer nil)
(defvar my/wst-stream-refresh-state nil)
(defvar my/wst-stream-refresh-dir nil)
(defvar my/wst-dirty-tree-root nil)
(defvar my/wst-dirty-tree-paths (make-hash-table :test #'equal))
(defvar my/wst-dirty-tree-statuses (make-hash-table :test #'equal))
(defvar my/wst-next-stream-pane-dir nil)
(defvar my/wst-confirming-exit nil)

(defun my/wst-git-status-state (dir)
  "Return a stable hash for DIR's worktree state."
  (let ((default-directory dir))
    (with-temp-buffer
      (when (zerop (call-process "git" nil t nil
                                 "status" "--porcelain=v1" "-z"
                                 "--untracked-files=normal"))
        (secure-hash 'sha1 (current-buffer))))))

(defun my/wst-git-status-kind (status)
  "Return a compact status kind for a porcelain STATUS."
  (cond
   ((string= status "??") 'untracked)
   ((string-match-p "U" status) 'conflict)
   ((string-match-p "D" status) 'deleted)
   ((string-match-p "A" status) 'added)
   ((string-match-p "R" status) 'renamed)
   (t 'modified)))

(defun my/wst-git-status-label (kind)
  "Return a short label for git status KIND."
  (pcase kind
    ('added "A")
    ('deleted "D")
    ('renamed "R")
    ('untracked "?")
    ('conflict "!")
    (_ "M")))

(defun my/wst-git-status-face (kind)
  "Return a Treemacs git face for git status KIND."
  (pcase kind
    ('added 'treemacs-git-added-face)
    ('deleted 'treemacs-git-conflict-face)
    ('renamed 'treemacs-git-renamed-face)
    ('untracked 'treemacs-git-untracked-face)
    ('conflict 'treemacs-git-conflict-face)
    (_ 'treemacs-git-modified-face)))

(defun my/wst-git-dirty-paths (dir &optional statuses)
  "Return a hash table of dirty files and ancestor directories in DIR."
  (let ((root (file-name-as-directory (expand-file-name dir)))
        (paths (make-hash-table :test #'equal)))
    (cl-labels
        ((mark-path (relative &optional status)
           (let ((path (directory-file-name (expand-file-name relative root))))
             (puthash path t paths)
             (when (and statuses status)
               (puthash path (my/wst-git-status-kind status) statuses))
             (let ((parent (file-name-directory path)))
               (while (and parent
                           (file-in-directory-p parent root)
                           (not (equal (directory-file-name parent)
                                       (directory-file-name root))))
                 (puthash (directory-file-name parent) t paths)
                 (setq parent (file-name-directory
                               (directory-file-name parent))))))))
      (with-temp-buffer
        (when (zerop (let ((default-directory root))
                       (call-process "git" nil t nil
                                     "status" "--porcelain=v1" "-z"
                                     "--untracked-files=normal")))
          (dolist (entry (split-string (buffer-string) "\0" t))
            (when (string-match-p "\\`[ MADRCU?!][ MADRCU?!] " entry)
              (mark-path (substring entry 3) (substring entry 0 2)))))))
    paths))

(defun my/wst-refresh-dirty-tree-paths (dir)
  (let ((statuses (make-hash-table :test #'equal)))
    (setq my/wst-dirty-tree-root (file-name-as-directory (expand-file-name dir))
          my/wst-dirty-tree-paths (my/wst-git-dirty-paths dir statuses)
          my/wst-dirty-tree-statuses statuses))
  (my/wst-apply-dirty-status-annotations))

(defun my/wst-dirty-tree-has-files-p ()
  "Return non-nil when WST dirty-tree state has file entries to display."
  (and (hash-table-p my/wst-dirty-tree-statuses)
       (> (hash-table-count my/wst-dirty-tree-statuses) 0)))

(defun my/wst-ensure-dirty-tree-tables ()
  "Ensure WST dirty-tree hash tables exist after config reloads."
  (unless (hash-table-p my/wst-dirty-tree-paths)
    (setq my/wst-dirty-tree-paths (make-hash-table :test #'equal)))
  (unless (hash-table-p my/wst-dirty-tree-statuses)
    (setq my/wst-dirty-tree-statuses (make-hash-table :test #'equal))))

(defun my/wst-apply-dirty-status-annotations ()
  "Apply WST git status suffixes to visible Treemacs nodes."
  (my/wst-ensure-dirty-tree-tables)
  (when (and (require 'treemacs nil t)
             (fboundp 'treemacs-set-annotation-suffix)
             (fboundp 'treemacs-set-annotation-face))
    (treemacs-clear-annotation-suffixes "wst-git-status")
    (treemacs-clear-annotation-faces "wst-git-status")
    (maphash
     (lambda (path kind)
       (let* ((face (my/wst-git-status-face kind))
              (suffix (propertize (concat " " (my/wst-git-status-label kind))
                                  'face face)))
         (treemacs-set-annotation-suffix path suffix "wst-git-status")
         (treemacs-set-annotation-face path face "wst-git-status")))
     my/wst-dirty-tree-statuses)
    (treemacs-run-in-every-buffer
     (when (fboundp 'treemacs-apply-annotations-in-buffer)
       (treemacs-apply-annotations-in-buffer (current-buffer))))))

(defun my/wst-treemacs-hide-clean-path-p (path _git-info)
  "Hide clean PATHs in the wst stream Treemacs pane."
  (my/wst-ensure-dirty-tree-tables)
  (and my/wst-dirty-tree-root
       (file-in-directory-p path my/wst-dirty-tree-root)
       (not (gethash (directory-file-name (expand-file-name path))
                     my/wst-dirty-tree-paths))))

(defun my/wst-show-treemacs-stream-project (dir &optional reset)
  "Replace Treemacs' workspace with the explicit WST stream project DIR."
  (when (and (require 'treemacs nil t)
             (fboundp 'treemacs--show-single-project))
    (when reset
      (when-let ((buf (treemacs-get-local-buffer)))
        (kill-buffer buf)))
    (let* ((path (directory-file-name (expand-file-name dir)))
           (name (file-name-nondirectory path)))
      (treemacs--show-single-project path name)
      (treemacs--find-project-for-path path))))

(defun my/wst-refresh-treemacs-project (dir)
  "Force Treemacs to rebuild the project containing DIR."
  (when (require 'treemacs nil t)
    (treemacs-run-in-every-buffer
     (when-let ((project (or (treemacs--find-project-for-path dir)
                             (my/wst-show-treemacs-stream-project dir :reset))))
       (treemacs--do-refresh (current-buffer) project)
       (if (my/wst-dirty-tree-has-files-p)
           (progn
             (my/wst-expand-treemacs-project project)
             (run-at-time 0.2 nil #'my/wst-expand-treemacs-project-for-dir dir))
         (my/wst-collapse-treemacs-project project))))))

(defun my/wst-collapse-treemacs-project (project)
  "Collapse PROJECT recursively in the WST Treemacs pane."
  (when (and (require 'treemacs nil t)
             (fboundp 'treemacs-project->position)
             (fboundp 'treemacs--collapse-root-node))
    (treemacs-run-in-every-buffer
     (when-let ((pos (treemacs-project->position project)))
       (when (eq 'root-node-open (treemacs-button-get pos :state))
         (treemacs--collapse-root-node pos :recursive))))))

(defun my/wst-expand-treemacs-project (project)
  "Expand PROJECT recursively in the WST Treemacs pane."
  (when (and (require 'treemacs nil t)
             (fboundp 'treemacs-project->position)
             (fboundp 'treemacs--expand-root-node))
    (treemacs-run-in-every-buffer
     (when-let ((pos (treemacs-project->position project)))
       (when (eq 'root-node-closed (treemacs-button-get pos :state))
         (treemacs--expand-root-node pos))
       (let ((changed t)
             (passes 0))
         (while (and changed (< passes 50))
           (setq changed nil
                 passes (1+ passes))
           (save-excursion
             (goto-char (point-min))
             (while-let ((button (next-button (point))))
               (goto-char (button-start button))
               (when (eq 'dir-node-closed (treemacs-button-get button :state))
                 (treemacs--expand-dir-node button)
                 (setq changed t))
               (goto-char (button-end button))))))))))

(defun my/wst-expand-treemacs-project-for-dir (dir)
  "Expand the Treemacs project for DIR using fresh Treemacs state."
  (when (require 'treemacs nil t)
    (treemacs-run-in-every-buffer
     (when-let ((project (treemacs--find-project-for-path dir)))
       (when (my/wst-dirty-tree-has-files-p)
         (my/wst-expand-treemacs-project project))))))

(defun my/wst-stop-magit-refresh-h ()
  (when (timerp my/wst-magit-refresh-timer)
    (cancel-timer my/wst-magit-refresh-timer)
    (setq my/wst-magit-refresh-timer nil)))

(defun my/wst-stop-stream-refresh ()
  (when (and (boundp 'my/wst-stream-refresh-timer)
             (timerp my/wst-stream-refresh-timer))
    (cancel-timer my/wst-stream-refresh-timer))
  (setq my/wst-stream-refresh-timer nil
        my/wst-stream-refresh-state nil
        my/wst-stream-refresh-dir nil))

(defun my/wst-refresh-treemacs-git-state ()
  "Refresh Treemacs git decorations for the current Magit repository."
  (when (require 'treemacs-magit nil t)
    (treemacs-magit--schedule-update)))

(defun my/wst-refresh-stream-if-changed (dir)
  "Refresh WST Magit and Treemacs state when DIR's worktree changes."
  (let ((state (my/wst-git-status-state dir)))
    (unless (equal state my/wst-stream-refresh-state)
      (setq my/wst-stream-refresh-state state)
      (my/wst-refresh-dirty-tree-paths dir)
      (dolist (buffer (buffer-list))
        (with-current-buffer buffer
          (when (and (derived-mode-p 'magit-status-mode)
                     (equal (file-name-as-directory (expand-file-name default-directory))
                            (file-name-as-directory (expand-file-name dir))))
            (setq-local my/wst-magit-refresh-state state)
            (magit-refresh-buffer))))
      (my/wst-refresh-treemacs-project dir)
      (my/wst-refresh-treemacs-git-state))))

(defun my/wst-enable-stream-refresh (dir)
  "Keep WST Magit and Treemacs dirty state current for DIR."
  (my/wst-stop-stream-refresh)
  (setq my/wst-stream-refresh-dir (file-name-as-directory (expand-file-name dir))
        my/wst-stream-refresh-state (my/wst-git-status-state dir)
        my/wst-stream-refresh-timer
        (run-at-time 2 2 #'my/wst-refresh-stream-if-changed
                     my/wst-stream-refresh-dir))
  (my/wst-refresh-dirty-tree-paths my/wst-stream-refresh-dir)
  (add-hook 'kill-emacs-hook #'my/wst-stop-stream-refresh))

(defun my/wst-refresh-magit-status-if-changed (buffer dir)
  (when (buffer-live-p buffer)
    (with-current-buffer buffer
      (when (and (derived-mode-p 'magit-status-mode)
                 (get-buffer-window buffer t))
        (let ((state (my/wst-git-status-state dir)))
          (unless (equal state my/wst-magit-refresh-state)
            (setq my/wst-magit-refresh-state state)
            (my/wst-refresh-dirty-tree-paths dir)
            (magit-refresh-buffer)
            (my/wst-refresh-treemacs-project dir)
            (my/wst-refresh-treemacs-git-state)))))))

(defun my/wst-enable-magit-status-refresh (dir)
  "Refresh the current Magit status buffer when visible worktree state changes."
  (my/wst-stop-magit-refresh-h)
  (setq-local my/wst-magit-refresh-state (my/wst-git-status-state dir)
              my/wst-magit-refresh-timer
              (run-at-time 2 2 #'my/wst-refresh-magit-status-if-changed
                           (current-buffer)
                           (file-name-as-directory (expand-file-name dir))))
  (add-hook 'kill-buffer-hook #'my/wst-stop-magit-refresh-h nil t))

(defun my/wst-open-stream-pane (dir)
  "Open a stream-scoped Treemacs + Magit layout for DIR."
  (interactive "DStream directory: ")
  (my/wst-stop-stream-refresh)
  (my/wst-ensure-dirty-tree-tables)
  (let ((dir (file-name-as-directory (expand-file-name dir))))
    (set-frame-parameter nil 'my/wst-stream-pane t)
    (my/wst-enable-stream-refresh dir)
    (add-hook 'treemacs-pre-file-insert-predicates
              #'my/wst-treemacs-hide-clean-path-p)
    (delete-other-windows)
    (magit-status dir)
    (my/wst-enable-magit-status-refresh dir)
    (let ((magit-buffer (current-buffer)))
      (my/wst-show-treemacs-stream-project dir :reset)
      (when (fboundp 'treemacs-select-window)
        (treemacs-select-window))
      (when-let ((project (treemacs--find-project-for-path dir)))
        (if (my/wst-dirty-tree-has-files-p)
            (progn
              (my/wst-expand-treemacs-project project)
              (run-at-time 0.2 nil #'my/wst-expand-treemacs-project-for-dir dir)
              (run-at-time 1 nil #'my/wst-expand-treemacs-project-for-dir dir))
          (my/wst-collapse-treemacs-project project)))
      (when (get-buffer-window magit-buffer t)
        (select-window (get-buffer-window magit-buffer t)))
      (my/wst-refresh-treemacs-git-state)
      (switch-to-buffer magit-buffer))))

(defun my/wst-open-next-stream-pane-h ()
  "Open a pending WST stream layout in a new server frame."
  (when my/wst-next-stream-pane-dir
    (let ((dir my/wst-next-stream-pane-dir))
      (setq my/wst-next-stream-pane-dir nil)
      (run-at-time 0 nil #'my/wst-open-stream-pane dir))))

(add-hook 'server-after-make-frame-hook #'my/wst-open-next-stream-pane-h)

(defun my/wst-stream-pane-frame-p (&optional frame)
  (frame-parameter frame 'my/wst-stream-pane))

(defun my/wst-confirm-stream-pane-exit ()
  (or my/wst-confirming-exit
      (let ((my/wst-confirming-exit t))
        (y-or-n-p "Close this WST Emacs pane? "))))

(defun my/wst-confirm-save-buffers-kill-terminal-a (fn &rest args)
  (when (or (not (my/wst-stream-pane-frame-p))
            (my/wst-confirm-stream-pane-exit))
    (apply fn args)))

(defun my/wst-confirm-delete-frame-a (fn &optional frame force)
  (when (or force
            (not (my/wst-stream-pane-frame-p frame))
            (my/wst-confirm-stream-pane-exit))
    (funcall fn frame force)))

(advice-remove #'save-buffers-kill-terminal
               #'my/wst-confirm-save-buffers-kill-terminal-a)
(advice-remove #'delete-frame
               #'my/wst-confirm-delete-frame-a)
(advice-add #'save-buffers-kill-terminal
            :around #'my/wst-confirm-save-buffers-kill-terminal-a)
(advice-add #'delete-frame
            :around #'my/wst-confirm-delete-frame-a)
