;;; $DOOMDIR/config.el -*- lexical-binding: t; -*-

;; Place your private configuration here! Remember, you do not need to run 'doom
;; sync' after modifying this file!

;; Always open maximized
(add-to-list 'default-frame-alist '(fullscreen . maximized))


;; Some functionality uses this to identify you, e.g. GPG configuration, email
;; clients, file templates and snippets. It is optional.
(setq user-full-name "{{ .name }}"
      user-mail-address "{{ .email }}")

;; Doom exposes five (optional) variables for controlling fonts in Doom:
;;
;; - `doom-font' -- the primary font to use
;; - `doom-variable-pitch-font' -- a non-monospace font (where applicable)
;; - `doom-big-font' -- used for `doom-big-font-mode'; use this for
;;   presentations or streaming.
;; - `doom-unicode-font' -- for unicode glyphs
;; - `doom-serif-font' -- for the `fixed-pitch-serif' face
;;
;; See 'C-h v doom-font' for documentation and more examples of what they
;; accept. For example:
;;
{{ if eq .chezmoi.os "darwin" -}}
(setq doom-font (font-spec :family "Hack Nerd Font" :size 14))
{{ else -}}
(setq doom-font (font-spec :family "Hack" :size 16))
{{ end -}}
;;
;; If you or Emacs can't find your font, use 'M-x describe-font' to look them
;; up, `M-x eval-region' to execute elisp code, and 'M-x doom/reload-font' to
;; refresh your font settings. If Emacs still can't find your font, it likely
;; wasn't installed correctly. Font issues are rarely Doom issues!

;; There are two ways to load a theme. Both assume the theme is installed and
;; available. You can either set `doom-theme' or manually load a theme with the
;; `load-theme' function. This is the default:
(setq doom-theme 'doom-dracula)

;; This determines the style of line numbers in effect. If set to `nil', line
;; numbers are disabled. For relative line numbers, set this to `relative'.
(setq display-line-numbers-type t)

;; If you use `org' and don't want your org files in the default location below,
;; change `org-directory'. It must be set before org loads!
(setq org-directory "~/Documents/Notes")
(setq org-agenda-files (directory-files-recursively "~/Documents/Notes" "\\.org$"))

;; Whenever you reconfigure a package, make sure to wrap your config in an
;; `after!' block, otherwise Doom's defaults may override your settings. E.g.
;;
;;   (after! PACKAGE
;;     (setq x y))
;;
;; The exceptions to this rule:
;;
;;   - Setting file/directory variables (like `org-directory')
;;   - Setting variables which explicitly tell you to set them before their
;;     package is loaded (see 'C-h v VARIABLE' to look up their documentation).
;;   - Setting doom variables (which start with 'doom-' or '+').
;;
;; Here are some additional functions/macros that will help you configure Doom.
;;
;; - `load!' for loading external *.el files relative to this one
;; - `use-package!' for configuring packages
;; - `after!' for running code after a package has loaded
;; - `add-load-path!' for adding directories to the `load-path', relative to
;;   this file. Emacs searches the `load-path' when you load packages with
;;   `require' or `use-package'.
;; - `map!' for binding new keys
;;
;; To get information about any of these functions/macros, move the cursor over
;; the highlighted symbol at press 'K' (non-evil users must press 'C-c c k').
;; This will open documentation for it, including demos of how they are used.
;; Alternatively, use `C-h o' to look up a symbol (functions, variables, faces,
;; etc).
;;
;; You can also try 'gd' (or 'C-c c d') to jump to their definition and see how
;; they are implemented.

(map! :leader :desc "Autoformat" "t a" #'apheleia-mode)
(add-to-list 'safe-local-eval-forms '(apheleia-mode -1))

;; Use format-all formatter for javascript (prettier) and python (ruff)
(setq-hook! 'rjsx-mode-hook +format-with-lsp nil)
(setq-hook! 'typescript-mode-hook +format-with-lsp nil)
(setq-hook! 'typescript-ts-mode-hook +format-with-lsp nil)
(setq-hook! 'tsx-ts-mode-hook +format-with-lsp nil)
(setq-hook! 'js2-mode-hook +format-with-lsp nil)
(setq-hook! 'js-ts-mode-hook +format-with-lsp nil)
(setq-hook! 'python-mode-hook +format-with-lsp nil)
(setq-hook! 'python-ts-mode-hook +format-with-lsp nil)
(setq-hook! 'web-mode-hook +format-with-lsp nil)

;; Docker-compose file association
(add-to-list 'auto-mode-alist '("docker-compose[^/]*\\.ya?ml\\'" . yaml-mode))

;; Tailwind CSS LSP — runs as add-on alongside existing LSP servers
(use-package! lsp-tailwindcss
  :when (modulep! :tools lsp)
  :init
  (setq lsp-tailwindcss-add-on-mode t)
  :config
  (dolist (mode '(rjsx-mode typescript-mode typescript-tsx-mode tsx-ts-mode web-mode))
    (add-to-list 'lsp-tailwindcss-major-modes mode))
  (lsp-register-client
   (make-lsp-client
    :new-connection (lsp-stdio-connection '("tailwindcss-language-server" "--stdio"))
    :activation-fn #'lsp-tailwindcss--activate-p
    :server-id 'tailwindcss
    :priority -1
    :add-on? lsp-tailwindcss-add-on-mode
    :initialization-options #'lsp-tailwindcss--initialization-options)))

;; Enable fuzzy matching in vertico (orderless)
(after! orderless
  (setq orderless-matching-styles '(orderless-flex)))

;; Ruff formatter for Python (replaces black)
(after! python
  (set-formatter! 'ruff-format "ruff format -" :modes '(python-mode python-ts-mode)))

;; Live-refresh buffers when files change on disk (e.g. Claude Code edits).
;; Pair with `:ui vc-gutter` to get live fringe markers without manual revert.
(setq auto-revert-verbose nil
      auto-revert-use-notify t
      auto-revert-avoid-polling t
      auto-revert-interval 2
      auto-revert-stop-on-user-input nil)
(global-auto-revert-mode 1)

;; Show git state in Treemacs for both files and parent directories. Doom's
;; default is `simple', which only decorates file nodes.
(setq +treemacs-git-mode 'deferred)

(after! treemacs
  (setq treemacs-silent-filewatch t
        treemacs-silent-refresh t)
  (treemacs-filewatch-mode 1))

;; Keep Magit status useful as a passive worktree monitor. File buffers use
;; notifications above; only Magit status buffers opt back into timer checks.
(after! magit
  (setq magit-auto-revert-immediately t)
  (add-hook! 'magit-status-mode-hook
    (defun my/magit-status-auto-refresh-h ()
      (setq-local auto-revert-avoid-polling nil)
      (auto-revert-mode 1))))

(defvar-local my/wst-magit-refresh-timer nil)
(defvar-local my/wst-magit-refresh-state nil)
(defvar my/wst-dirty-tree-root nil)
(defvar my/wst-dirty-tree-paths (make-hash-table :test #'equal))

(defun my/wst-git-status-state (dir)
  "Return a stable hash for DIR's worktree state."
  (let ((default-directory dir))
    (with-temp-buffer
      (when (zerop (call-process "git" nil t nil
                                 "status" "--porcelain=v1" "-z"
                                 "--untracked-files=normal"))
        (secure-hash 'sha1 (current-buffer))))))

(defun my/wst-git-dirty-paths (dir)
  "Return a hash table of dirty files and ancestor directories in DIR."
  (let ((root (file-name-as-directory (expand-file-name dir)))
        (paths (make-hash-table :test #'equal)))
    (cl-labels
        ((mark-path (relative)
           (let ((path (directory-file-name (expand-file-name relative root))))
             (puthash path t paths)
             (let ((parent (file-name-directory path)))
               (while (and parent
                           (file-in-directory-p parent root)
                           (not (equal (directory-file-name parent)
                                       (directory-file-name root))))
                 (puthash (directory-file-name parent) t paths)
                 (setq parent (file-name-directory
                               (directory-file-name parent))))))))
      (with-temp-buffer
        (when (zerop (let ((default-directory root))
                       (call-process "git" nil t nil
                                     "status" "--porcelain=v1" "-z"
                                     "--untracked-files=normal")))
          (dolist (entry (split-string (buffer-string) "\0" t))
            (when (string-match-p "\\`[ MADRCU?!][ MADRCU?!] " entry)
              (mark-path (substring entry 3)))))))
    paths))

(defun my/wst-refresh-dirty-tree-paths (dir)
  (setq my/wst-dirty-tree-root (file-name-as-directory (expand-file-name dir))
        my/wst-dirty-tree-paths (my/wst-git-dirty-paths dir)))

(defun my/wst-treemacs-hide-clean-path-p (path _git-info)
  "Hide clean PATHs in the wst stream Treemacs pane."
  (and my/wst-dirty-tree-root
       (file-in-directory-p path my/wst-dirty-tree-root)
       (not (gethash (directory-file-name (expand-file-name path))
                     my/wst-dirty-tree-paths))))

(defun my/wst-refresh-treemacs-project (dir)
  "Force Treemacs to rebuild the project containing DIR."
  (when (require 'treemacs nil t)
    (treemacs-run-in-every-buffer
     (when-let ((project (treemacs--find-project-for-path dir)))
       (treemacs--do-refresh (current-buffer) project)))))

(defun my/wst-stop-magit-refresh-h ()
  (when (timerp my/wst-magit-refresh-timer)
    (cancel-timer my/wst-magit-refresh-timer)
    (setq my/wst-magit-refresh-timer nil)))

(defun my/wst-refresh-treemacs-git-state ()
  "Refresh Treemacs git decorations for the current Magit repository."
  (when (require 'treemacs-magit nil t)
    (treemacs-magit--schedule-update)))

(defun my/wst-refresh-magit-status-if-changed (buffer dir)
  (when (buffer-live-p buffer)
    (with-current-buffer buffer
      (when (and (derived-mode-p 'magit-status-mode)
                 (get-buffer-window buffer t))
        (let ((state (my/wst-git-status-state dir)))
          (unless (equal state my/wst-magit-refresh-state)
            (setq my/wst-magit-refresh-state state)
            (my/wst-refresh-dirty-tree-paths dir)
            (magit-refresh-buffer)
            (my/wst-refresh-treemacs-project dir)
            (my/wst-refresh-treemacs-git-state)))))))

(defun my/wst-enable-magit-status-refresh (dir)
  "Refresh the current Magit status buffer when visible worktree state changes."
  (my/wst-stop-magit-refresh-h)
  (setq-local my/wst-magit-refresh-state (my/wst-git-status-state dir)
              my/wst-magit-refresh-timer
              (run-at-time 2 2 #'my/wst-refresh-magit-status-if-changed
                           (current-buffer)
                           (file-name-as-directory (expand-file-name dir))))
  (add-hook 'kill-buffer-hook #'my/wst-stop-magit-refresh-h nil t))

(defun my/wst-open-stream-pane (dir)
  "Open a stream-scoped Treemacs + Magit layout for DIR."
  (interactive "DStream directory: ")
  (let ((dir (file-name-as-directory (expand-file-name dir))))
    (my/wst-refresh-dirty-tree-paths dir)
    (add-hook 'treemacs-pre-file-insert-predicates
              #'my/wst-treemacs-hide-clean-path-p)
    (delete-other-windows)
    (magit-status dir)
    (my/wst-enable-magit-status-refresh dir)
    (let ((magit-buffer (current-buffer)))
      (when (fboundp 'treemacs-add-and-display-current-project-exclusively)
        (treemacs-add-and-display-current-project-exclusively))
      (when (fboundp 'treemacs-select-window)
        (treemacs-select-window))
      (when (get-buffer-window magit-buffer t)
        (select-window (get-buffer-window magit-buffer t)))
      (my/wst-refresh-treemacs-git-state)
      (switch-to-buffer magit-buffer))))
