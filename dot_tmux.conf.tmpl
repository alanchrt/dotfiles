# install plugins
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'dracula/tmux'

# configure dracula bottom bar
set -g @dracula-show-left-icon session
set -g @dracula-plugins " "

# use pretty colors
set -g default-terminal "tmux-256color"
set -g focus-events on

# switch to ctrl+a prefix
unbind-key C-b
set-option -g prefix C-a
bind-key a send-prefix

# custom shell bindings
bind P new-window -n ipy ipython3 --no-banner --nosep --no-confirm-exit
bind B new-window -n bib $HOME/.local/bin/bib
bind g run-shell "$HOME/.local/bin/wst-codex-popup"
bind o run-shell "$HOME/.local/bin/wst-cycle-pane"

# stream-aware split bindings: if the current window has @wst-workdir set
# (created by `wst new`/`wa`), the new pane auto-execs into the devcontainer.
unbind '"'
unbind %
bind '"' run-shell '~/.local/bin/wst-tmux-split v'
bind % run-shell '~/.local/bin/wst-tmux-split h'

# use vi keys in copy mode
set-window-option -g mode-keys vi

# copy binding
bind-key -T copy-mode-vi v send-keys -X begin-selection
{{ if eq .chezmoi.os "darwin" -}}
bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "pbcopy"
{{ else -}}
bind-key -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "xclip -selection clipboard > /dev/null"
{{ end -}}

# initialize plugins
run '~/.tmux/plugins/tpm/tpm'
