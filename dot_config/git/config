[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	line-numbers = true
	side-by-side = true
	syntax-theme = Dracula

# Named feature: unified (non-side-by-side) for narrow panels like
# lazygit's diff pane. Activate with `delta --features=narrow`.
[delta "narrow"]
	side-by-side = false
