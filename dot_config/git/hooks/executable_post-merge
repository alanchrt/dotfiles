#!/bin/bash
set -euo pipefail

# Global post-merge hook: runs after git pull (fast-forward or merge).

# Chain to repo-local hook if it exists (core.hooksPath shadows per-repo hooks).
# Skip if we were already called FROM a local hook (template chaining) to avoid loops.
if [[ -z "${_CHAINED_FROM_LOCAL:-}" ]]; then
    local_hook="$(git rev-parse --git-dir)/hooks/post-merge"
    if [[ -x "$local_hook" ]]; then
        export _CHAINED_FROM_GLOBAL=1
        "$local_hook" "$@"
    fi
fi

# Clean up merged worktree branches
"$(dirname "$0")/cleanup-merged-worktrees"
