#!/bin/bash
set -euo pipefail

# Global post-rewrite hook: runs after git rebase or git commit --amend.

# Chain to repo-local hook if it exists (core.hooksPath shadows per-repo hooks)
local_hook="$(git rev-parse --git-dir)/hooks/post-rewrite"
if [[ -x "$local_hook" ]]; then
    "$local_hook" "$@"
fi

# Only clean up after rebase (covers git pull --rebase), not amend
if [[ "${1:-}" == "rebase" ]]; then
    "$(dirname "$0")/cleanup-merged-worktrees"
fi
