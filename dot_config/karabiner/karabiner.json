{
    "profiles": [
        {
            "name": "Default",
            "selected": true,
            "simple_modifications": [
                {
                    "from": { "key_code": "left_command" },
                    "to": [{ "key_code": "left_option" }]
                },
                {
                    "from": { "key_code": "left_option" },
                    "to": [{ "key_code": "left_command" }]
                }
            ],
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Alt+H/L to switch apps",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "h",
                                    "modifiers": {
                                        "mandatory": ["left_option"]
                                    }
                                },
                                "to": [
                                    {
                                        "key_code": "tab",
                                        "modifiers": ["left_command", "left_shift"]
                                    }
                                ]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "l",
                                    "modifiers": {
                                        "mandatory": ["left_option"]
                                    }
                                },
                                "to": [
                                    {
                                        "key_code": "tab",
                                        "modifiers": ["left_command"]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "description": "Alt+Enter to open Alacritty+tmux",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "return_or_enter",
                                    "modifiers": {
                                        "mandatory": ["left_option"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [
                                    {
                                        "shell_command": "open -na Alacritty --args --command /opt/homebrew/bin/tmux new-session"
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            "virtual_hid_keyboard": { "keyboard_type_v2": "ansi" }
        }
    ]
}
