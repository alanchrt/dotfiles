#!/usr/bin/env bash
# Toggle a tmux popup attached to a persistent side Codex session. Closing the
# popup detaches only the attached client; the side session keeps running.

set -euo pipefail

slugify() {
  printf '%s' "$1" | tr '/' '-' | tr -c 'A-Za-z0-9._-' '-'
}

tmux_cmd=(tmux)
if [[ -n "${TMUX:-}" ]]; then
  tmux_cmd=(tmux -S "${TMUX%%,*}")
fi

current_session=$("${tmux_cmd[@]}" display-message -p '#{client_session}' 2>/dev/null || true)
if [[ "$current_session" == wst-codex-popup-* ]]; then
  exec "${tmux_cmd[@]}" detach-client
fi

socket_path=$("${tmux_cmd[@]}" display-message -p '#{socket_path}')
project=$("${tmux_cmd[@]}" show-options -wqv @wst-project 2>/dev/null || true)
stream=$("${tmux_cmd[@]}" show-options -wqv @wst-stream 2>/dev/null || true)
workdir=$("${tmux_cmd[@]}" show-options -wqv @wst-workdir 2>/dev/null || true)

if [[ -n "$project" && -n "$stream" && -n "$workdir" && -d "$workdir" ]]; then
  session="wst-codex-popup-$(slugify "$project")-$(slugify "$stream")"
  if ! "${tmux_cmd[@]}" has-session -t "$session" 2>/dev/null; then
    printf -v command 'devcontainer exec --workspace-folder %q zsh -l -c %q' \
      "$workdir" 'codex; exec zsh -l'
    "${tmux_cmd[@]}" new-session -d -s "$session" -c "$workdir" "$command"
  fi
else
  session="wst-codex-popup-host"
  if ! "${tmux_cmd[@]}" has-session -t "$session" 2>/dev/null; then
    "${tmux_cmd[@]}" new-session -d -s "$session" 'codex; exec "${SHELL:-zsh}" -l'
  fi
fi

exec "${tmux_cmd[@]}" display-popup -E -w 90% -h 85% -T "Codex side quest" \
  "env -u TMUX tmux -S '$socket_path' attach-session -t '$session'"
