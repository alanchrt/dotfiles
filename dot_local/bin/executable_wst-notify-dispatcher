#!/usr/bin/env bash
# wst-notify-dispatcher — host-side daemon that watches
# $HOME/.cache/wst/notify-queue/ for JSON files produced by
# ~/.claude/hooks/notify-input.sh (running on host or inside a stream's
# devcontainer) and dispatches each as a desktop notification with a "Focus"
# action. Click → focus the matching tmux window/pane + raise the Alacritty
# client. Run as a systemd user service (wst-notify-dispatcher.service).

set -euo pipefail

queue_dir="$HOME/.cache/wst/notify-queue"
mkdir -p "$queue_dir"

# Map a project name to its tmux session name (mirrors `session_name` in wst:
# replace '.' with '_').
session_for_project() {
  printf '%s' "$1" | sed 's/\./_/g'
}

# Map a branch to the same slug wst uses for the window name.
slug_for_branch() {
  printf '%s' "$1" | tr '/' '-' | tr -c 'A-Za-z0-9._-' '-'
}

dispatch_one() {
  local file="$1"
  [[ -f "$file" ]] || return 0

  local title body pane_target wst_project wst_stream
  title=$(jq -r '.title // ""' "$file" 2>/dev/null || true)
  body=$(jq -r '.body // ""' "$file" 2>/dev/null || true)
  pane_target=$(jq -r '.pane_target // ""' "$file" 2>/dev/null || true)
  wst_project=$(jq -r '.wst_project // ""' "$file" 2>/dev/null || true)
  wst_stream=$(jq -r '.wst_stream // ""' "$file" 2>/dev/null || true)
  rm -f "$file"

  # Resolve pane_target from wst metadata if the hook couldn't (in-container case)
  if [[ -z "$pane_target" && -n "$wst_project" && -n "$wst_stream" ]] \
       && command -v tmux >/dev/null 2>&1; then
    local session slug win_index
    session=$(session_for_project "$wst_project")
    slug=$(slug_for_branch "$wst_stream")
    win_index=$(tmux list-windows -t "$session" -F '#{window_index} #{window_name}' 2>/dev/null \
      | awk -v slug="$slug" '$2==slug {print $1; exit}')
    [[ -n "$win_index" ]] && pane_target="$session:$win_index"
  fi

  # Skip notification if the pane (or its window) is already focused.
  if [[ -n "$pane_target" ]] && command -v tmux >/dev/null 2>&1; then
    local active
    active=$(tmux list-panes -a \
      -F "#{pane_active} #{window_active} #{session_name}:#{window_index}.#{pane_index}" \
      2>/dev/null | awk -v t="$pane_target" '
        $1=="1" && $2=="1" {
          full=$3
          # Try matching either "session:window" or "session:window.pane"
          short=full; sub(/\..*/, "", short)
          if (full==t || short==t) {print "yes"; exit}
        }')
    if [[ "$active" == "yes" ]]; then
      local session client_focused
      session="${pane_target%%:*}"
      client_focused=$(tmux list-clients -t "$session" -F "#{client_flags}" 2>/dev/null \
        | grep -c "focused" || true)
      [[ "$client_focused" -gt 0 ]] && return 0
    fi
  fi

  # Dispatch in a backgrounded subshell so multiple notifications can be
  # waiting on user click concurrently.
  (
    local action
    if [[ -n "$pane_target" ]]; then
      action=$(notify-send -i dialog-information -A "default=Focus" "$title" "$body" 2>/dev/null || true)
      if [[ "$action" == "default" ]]; then
        local win="${pane_target%.*}"
        tmux select-window -t "$win" 2>/dev/null || true
        tmux select-pane  -t "$pane_target" 2>/dev/null || true
        # Raise the Alacritty client attached to that session
        if command -v wmctrl >/dev/null 2>&1; then
          local session client_pid alacritty_pid pname win_id
          session="${pane_target%%:*}"
          client_pid=$(tmux list-clients -t "$session" -F "#{client_pid}" 2>/dev/null | head -1)
          if [[ -n "$client_pid" ]]; then
            alacritty_pid=$(ps -o ppid= -p "$client_pid" 2>/dev/null | tr -d ' ')
            pname=$(ps -o comm= -p "$alacritty_pid" 2>/dev/null | tr -d ' ')
            if [[ "$pname" == "alacritty" ]]; then
              win_id=$(wmctrl -l -p 2>/dev/null \
                | awk -v pid="$alacritty_pid" '$3==pid {print $1; exit}')
              [[ -n "$win_id" ]] && wmctrl -i -a "$win_id" 2>/dev/null || true
            fi
          fi
        fi
      fi
    else
      # No pane target known — fire a plain notification.
      notify-send -i dialog-information "$title" "$body" 2>/dev/null || true
    fi
  ) &
  disown
}

# Drain anything already in the queue from before the service started.
for f in "$queue_dir"/*.json; do
  [[ -f "$f" ]] && dispatch_one "$f"
done

# Watch for new files. close_write + moved_to covers atomic writes
# (the hook uses .tmp + mv).
exec inotifywait -m -e close_write,moved_to --format '%w%f' "$queue_dir" \
  | while read -r path; do
      [[ "$path" == *.json ]] && dispatch_one "$path"
    done
