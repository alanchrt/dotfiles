#!/usr/bin/env bash

set -euo pipefail

if command -v wl-paste >/dev/null 2>&1 && [[ -n "${WAYLAND_DISPLAY:-}" || -n "${WAYLAND_SOCKET:-}" ]]; then
  exec wl-paste --no-newline
fi

if command -v pbpaste >/dev/null 2>&1; then
  exec pbpaste
fi

if command -v xclip >/dev/null 2>&1; then
  exec xclip -selection clipboard -out
fi

if command -v xsel >/dev/null 2>&1; then
  exec xsel --clipboard --output
fi

echo "desktop-clipboard-paste: no supported clipboard tool found" >&2
exit 1
