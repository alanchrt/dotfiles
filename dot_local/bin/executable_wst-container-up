#!/usr/bin/env bash
# wst-container-up — invoke `devcontainer up` for a stream.
#
# In @devcontainers/cli 0.87.0+ `--override-config` *replaces* the project's
# devcontainer.json (it used to merge). We work around this by pre-merging:
# read the project's config, append our mounts/remoteEnv/runArgs onto whatever
# the project already has, resolve any relative build paths to absolute (the
# override lives outside .devcontainer/), and hand the merged result to
# --override-config. The CLI's --mount flag would have been simpler but its
# parser rejects `readonly`, so we keep mounts in the JSON form instead.
#
# Required env (set by wst orchestrator):
#   WST_PROJECT    project name
#   WST_BRANCH     git branch name (not slugged)
#   WST_SLUG       slugified branch (dir name)
#   WST_TARGET     absolute workspace folder
#   WST_HOST_PORT  host port to forward
# Optional env:
#   WST_CONTAINER_PORT (default: project's first forwardPorts entry, else $DEFAULT_CONTAINER_PORT)

set -euo pipefail

DEFAULT_CONTAINER_PORT=3000

: "${WST_PROJECT:?required}"
: "${WST_BRANCH:?required}"
: "${WST_SLUG:?required}"
: "${WST_TARGET:?required}"
: "${WST_HOST_PORT:?required}"

STATE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/wst"
OVERRIDES_DIR="$STATE_DIR/overrides"
WST_DEV_IMAGE="${WST_DEV_IMAGE:-wst-dev:latest}"
WST_CHROMIUM_VOLUME="${WST_CHROMIUM_VOLUME:-wst-chromium-profile}"
NOTIFY_QUEUE_DIR="$STATE_DIR/notify-queue"
mkdir -p "$OVERRIDES_DIR" "$NOTIFY_QUEUE_DIR"

die() { printf 'wst-container-up: %s\n' "$*" >&2; exit 1; }

# Locate the project's devcontainer.json. If the project does not provide one,
# use WST's central fallback config so generic repos can still become streams.
project_dc="$WST_TARGET/.devcontainer/devcontainer.json"
[[ -f "$project_dc" ]] || project_dc="$WST_TARGET/.devcontainer.json"
if [[ ! -f "$project_dc" ]]; then
  project_dc="${WST_DEFAULT_DEVCONTAINER:-$HOME/.local/share/wst/default-devcontainer/devcontainer.json}"
  [[ -f "$project_dc" ]] || die "no devcontainer.json found in $WST_TARGET and fallback missing at $project_dc"
  printf 'wst-container-up: no project devcontainer found; using fallback %s\n' "$project_dc" >&2
fi
project_dc_dir="$(dirname "$project_dc")"

# devcontainer.json is JSONC; strip comments defensively before handing to jq
project_json=$(sed 's|//.*$||; s|/\*.*\*/||' "$project_dc")

# Default GITHUB_TOKEN from `gh auth token` if the shell env doesn't set it
if [[ -z "${GITHUB_TOKEN:-}" ]] && command -v gh >/dev/null 2>&1; then
  GITHUB_TOKEN=$(gh auth token 2>/dev/null || true)
fi

# Pick container port: explicit env > project's first forwardPorts entry > default
container_port="${WST_CONTAINER_PORT:-}"
if [[ -z "$container_port" ]]; then
  container_port=$(printf '%s' "$project_json" \
    | jq -r '.forwardPorts? // [] | .[0] // empty' 2>/dev/null || true)
fi
container_port="${container_port:-$DEFAULT_CONTAINER_PORT}"

chrome_volume="wst-chrome-$WST_PROJECT"
override="$OVERRIDES_DIR/$WST_PROJECT-$WST_SLUG.json"

# Collect wst mounts as devcontainer.json-style mount strings. Skip any whose
# host source doesn't exist (e.g. no ssh key set up yet).
wst_mounts=()
add_bind_ro() {
  local src="$1" dest="$2"
  [[ -e "$src" ]] || return 0
  wst_mounts+=("source=$src,target=$dest,type=bind,readonly")
}
add_bind_rw() {
  local src="$1" dest="$2"
  [[ -e "$src" ]] || return 0
  wst_mounts+=("source=$src,target=$dest,type=bind")
}
add_bind_ro "$HOME/.ssh/id_ed25519"      "/home/vscode/.ssh/id_ed25519"
add_bind_ro "$HOME/.ssh/id_ed25519.pub"  "/home/vscode/.ssh/id_ed25519.pub"
add_bind_ro "$HOME/.ssh/known_hosts"     "/home/vscode/.ssh/known_hosts"
# Host gitconfig is mounted at .host-gitconfig and included by the wst layer
# config below — this leaves room for our credential helper + URL rewrite to
# sit on top without touching the host's gitconfig.
add_bind_ro "$HOME/.gitconfig"           "/home/vscode/.host-gitconfig"
# Wst layer gitconfig: rewrites SSH-style github remotes to HTTPS and routes
# auth through `gh auth git-credential`. `gh` inside the container uses the
# forwarded GITHUB_TOKEN, so `git push` and `gt submit` work without an SSH
# agent or keyring access. The empty `helper =` line is the standard idiom
# for clearing any inherited credential helpers before appending ours.
container_gitconfig="$STATE_DIR/container-gitconfig"
cat > "$container_gitconfig" <<'GITCONFIG'
[include]
	path = ~/.host-gitconfig

[url "https://github.com/"]
	insteadOf = git@github.com:
	insteadOf = ssh://git@github.com/

[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
GITCONFIG
add_bind_ro "$container_gitconfig"       "/home/vscode/.gitconfig"
# Share only the auth-relevant files (not the whole config dir) so each
# container can still manage its own per-repo gh/gt state without the
# host's RO mount blocking writes. NOTE: hosts.yml is NOT bind-mounted —
# on hosts where gh stores its token in the keyring (secure_storage),
# gh inside the container tries to migrate it on first read and spawns
# dbus-launch, which isn't present. provision_container in `wst` writes
# a fresh container-local hosts.yml from GITHUB_TOKEN instead.
add_bind_ro "$HOME/.config/graphite/auth"    "/home/vscode/.config/graphite/auth"
add_bind_ro "$HOME/.config/graphite/aliases" "/home/vscode/.config/graphite/aliases"
# Shared Claude rule files (e.g. graphite.md). Mounted at the same literal path
# on host and inside the container so a single absolute symlink in a stream's
# working tree resolves on both sides — see `wst gtinit`.
add_bind_ro "$HOME/.local/share/claude-rules" "$HOME/.local/share/claude-rules"
# Downloads + Screenshots (RO). Mounted under the container user's HOME so
# `~/Downloads` and `~/Screenshots` work inside. Host screenshots live at
# ~/Pictures/Screenshots/ — flatten to ~/Screenshots/ for a shorter path.
add_bind_ro "$HOME/Downloads"                 "/home/vscode/Downloads"
add_bind_ro "$HOME/Pictures/Screenshots"      "/home/vscode/Screenshots"
# Full host ~/.claude/ (RW) so the in-container Claude Code sees the same
# settings.json, CLAUDE.md, hooks/, agents/, commands/, plans/, etc. Includes
# .credentials.json — refresh-token writes propagate back to the host.
add_bind_rw "$HOME/.claude" "/home/vscode/.claude"
# Claude Code user-level state file (sibling of .claude/ at $HOME). Stores
# theme, firstStartTime, project history, cached experiment features, etc.
# Without it every fresh container shows onboarding again.
add_bind_rw "$HOME/.claude.json" "/home/vscode/.claude.json"
# Codex CLI: same pattern. Full ~/.codex/ (RW) so the in-container Codex
# sees host's config.toml, AGENTS.md, and the OAuth auth state — log in
# once on the host (`codex` then sign in) and every stream inherits it.
add_bind_rw "$HOME/.codex" "/home/vscode/.codex"
# Shared codex rule files (e.g. graphite.md). Mounted at the same literal
# path host→container so `wst gtinit`'s AGENTS.override.md symlinks resolve
# inside the container.
add_bind_ro "$HOME/.local/share/codex-rules" "$HOME/.local/share/codex-rules"
# Notify queue: in-container Claude hooks write JSON here; the host-side
# wst-notify-dispatcher service watches the dir and dispatches via
# notify-send + tmux focus + wmctrl.
add_bind_rw "$NOTIFY_QUEUE_DIR" "/home/vscode/.cache/wst/notify-queue"
wst_mounts+=("source=$chrome_volume,target=/home/vscode/.config/chromium,type=volume")
# wst-dev shared resources:
# - Dotfiles source so the entrypoint's `chezmoi apply` finds it at the
#   path `dot_config/chezmoi/chezmoi.toml.tmpl` configures.
# - Shared dir between host and all containers.
# - mise install cache shared across every stream so installing node@20
#   in one stream is instantly available in the others.
# - powerlevel10k/gitstatus cache so fresh pane shells don't print
#   gitstatusd download progress before the first prompt.
# - docker socket for sibling compose stacks (microservice projects).
mkdir -p "$HOME/.cache/gitstatus"
add_bind_rw "$HOME/Projects/dotfiles/master" "/home/vscode/Projects/dotfiles/master"
add_bind_rw "$HOME/Projects/Shared"          "/home/vscode/Shared"
add_bind_rw "$HOME/.local/share/wst/mise"    "/home/vscode/.local/share/mise"
add_bind_rw "$HOME/.cache/gitstatus"         "/home/vscode/.cache/gitstatus"
add_bind_rw "/var/run/docker.sock"           "/var/run/docker.sock"
# Persistent Chromium profile (SSO/cookies) — single volume shared by every
# stream. `wst chrome` opens a headed Chromium against this profile so a
# one-time SSO bootstrap carries auth into headless MCP sessions.
wst_mounts+=("source=$WST_CHROMIUM_VOLUME,target=/home/vscode/.config/chromium-wst,type=volume")
# Wayland socket forwarding for headed Chromium handoff. The host's vscode
# user (uid 1000) matches the container user, so socket access works.
if [[ -n "${WAYLAND_DISPLAY:-}" && -n "${XDG_RUNTIME_DIR:-}" && \
      -S "$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY" ]]; then
  add_bind_rw "$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY" \
              "/run/user/1000/$WAYLAND_DISPLAY"
fi

# Encode wst mounts as a JSON array for jq to splice into the merged config.
wst_mounts_json=$(printf '%s\n' "${wst_mounts[@]}" | jq -R . | jq -s .)

# Build the merged override: project's full config + wst additions, with
# relative build paths resolved to absolute (override lives in ~/.cache/).
printf '%s' "$project_json" | jq \
  --arg host_port "$WST_HOST_PORT" \
  --arg cport "$container_port" \
  --arg dc_dir "$project_dc_dir" \
  --arg github_token "${GITHUB_TOKEN:-}" \
  --arg anthropic_key "${ANTHROPIC_API_KEY:-}" \
  --arg project "$WST_PROJECT" \
  --arg branch "$WST_BRANCH" \
  --argjson wst_mounts "$wst_mounts_json" \
  --arg wst_dev_image "$WST_DEV_IMAGE" \
  --arg wayland_display "${WAYLAND_DISPLAY:-}" \
  '
  def abs($p):
    if ($p | startswith("/")) then $p else $dc_dir + "/" + $p end;

  # Mega-image swap: discard the project image/build/features so every
  # stream boots wst-dev:latest. We keep mounts/ports/env/runArgs/
  # postCreateCommand from the project so the rest of the contract holds.
  .image = $wst_dev_image
  | del(.build)
  | del(.dockerFile)
  | del(.features)
  # devcontainer-cli overrides the image ENTRYPOINT with its own
  # (`docker-init.sh ... sleep infinity`), so our setup script must be
  # injected via the devcontainer spec lifecycle. postStartCommand runs on
  # every container boot (creation + subsequent starts), keeping dotfiles
  # in sync with the bind-mounted source. Prepend ours to any project-set
  # postStartCommand so both run.
  | .postStartCommand = (
      if (.postStartCommand // null) == null
      then "/usr/local/bin/wst-dev-entrypoint"
      elif (.postStartCommand | type) == "string"
      then "/usr/local/bin/wst-dev-entrypoint; " + .postStartCommand
      else "/usr/local/bin/wst-dev-entrypoint"
      end
    )
  | .mounts = ((.mounts // []) + $wst_mounts)
  | .remoteEnv = ((.remoteEnv // {}) + ({
      GITHUB_TOKEN: $github_token,
      ANTHROPIC_API_KEY: $anthropic_key,
      ADB_SERVER_SOCKET: "tcp:host.docker.internal:5037",
      TERM: "tmux-256color",
      COLORTERM: "truecolor",
      WST_PORT: $cport,
      WST_HOST_PORT: $host_port,
      WST_PROJECT: $project,
      WST_STREAM: $branch,
      WST_DOTFILES_SRC: "/home/vscode/Projects/dotfiles/master",
      WST_SHARED_DIR: "/home/vscode/Shared",
      WST_BROWSER_PROFILE: "/home/vscode/.config/chromium-wst",
      SHELL: "/usr/bin/zsh",
      WAYLAND_DISPLAY: $wayland_display,
      XDG_RUNTIME_DIR: "/run/user/1000",
      MOZ_ENABLE_WAYLAND: "1",
      PLAYWRIGHT_BROWSERS_PATH: "/opt/playwright-browsers"
    } | with_entries(select(.value != "" and .value != null))))
  | .runArgs = ((.runArgs // []) + [
      "--add-host=host.docker.internal:host-gateway",
      "-p", ($host_port + ":" + $cport)
    ])
  | if .build?.dockerfile  then .build.dockerfile  = abs(.build.dockerfile)  else . end
  | if .build?.context     then .build.context     = abs(.build.context)     else . end
  | if .dockerFile?        then .dockerFile        = abs(.dockerFile)        else . end
  | if .dockerComposeFile? then
      if (.dockerComposeFile | type) == "string" then
        .dockerComposeFile = abs(.dockerComposeFile)
      else
        .dockerComposeFile = (.dockerComposeFile | map(abs(.)))
      end
    else . end
  ' > "$override"

exec devcontainer up \
  --workspace-folder "$WST_TARGET" \
  --override-config "$override"
