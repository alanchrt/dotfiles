#!/usr/bin/env bash
# Toggle popup with a single text field to create a new wst stream.
# Outer mode: toggle open/close. Inner mode (WST_STREAM_CREATOR=1): run prompt.

set -euo pipefail

PROJECTS_ROOT="${WST_PROJECTS_ROOT:-$HOME/Projects}"
PIDFILE="${XDG_CACHE_HOME:-$HOME/.cache}/wst/stream-creator.pid"

session_name() { printf '%s' "$1" | sed -r 's/\./_/g'; }
slugify()      { printf '%s' "$1" | tr '/' '-' | tr -c 'A-Za-z0-9._-' '-'; }

# ── Outer (toggle) mode ──────────────────────────────────────────────────────
if [[ -z "${WST_STREAM_CREATOR:-}" ]]; then
  if [[ -f "$PIDFILE" ]]; then
    _pid=$(cat "$PIDFILE" 2>/dev/null || true)
    if [[ -n "$_pid" ]] && kill -0 "$_pid" 2>/dev/null; then
      kill "$_pid" 2>/dev/null || true
      exit 0
    fi
    rm -f "$PIDFILE"
  fi
  _cur_session=$(tmux display-message -p '#{session_name}')
  exec tmux display-popup \
    -E -w 60% -h 30% \
    "env WST_STREAM_CREATOR=1 WST_SESSION=$(printf '%q' "$_cur_session") $HOME/.local/bin/wst-stream-creator"
fi

# ── Prompt mode (inside popup) ───────────────────────────────────────────────
mkdir -p "$(dirname "$PIDFILE")"
printf '%d\n' "$$" > "$PIDFILE"
# Cleanup kills only the progress tail (a child of this popup), never the
# detached `wst new` — so prefix+W can hide the popup while creation continues.
tailpid=""
stty_saved=""
cleanup() {
  [[ -n "$tailpid" ]] && kill "$tailpid" 2>/dev/null || true
  [[ -n "$stty_saved" ]] && stty "$stty_saved" 2>/dev/null || true
  rm -f "$PIDFILE"
}
trap cleanup EXIT
trap 'exit 143' TERM HUP
trap 'exit 130' INT

# Resolve project from the session name passed by outer mode
proj=""
if [[ -n "${WST_SESSION:-}" ]]; then
  for _pdir in "$PROJECTS_ROOT"/*/; do
    [[ -d "$_pdir" ]] || continue
    _pname=$(basename "$_pdir")
    if [[ "$(session_name "$_pname")" == "$WST_SESSION" ]]; then
      proj="$_pname"
      break
    fi
  done
fi

if [[ -z "$proj" ]]; then
  printf '\n  \033[38;5;141mNot in a project session.\033[0m\n\n'
  printf '  Open this from a tmux session named after a project under %s.\n\n' "$PROJECTS_ROOT"
  printf '  \033[38;5;61mPress any key...\033[0m'
  read -r -n1
  exit 0
fi

# Prompt for the stream name. fzf with --print-query over empty input acts as a
# one-line text field: it prints whatever was typed when Enter is pressed
# (exits non-zero with no candidate, hence `|| true`).
name=$(
  printf '' | fzf \
    --print-query \
    --layout=reverse \
    --info=hidden \
    --border=rounded \
    --border-label="$(printf '  new stream in %s  ' "$proj")" \
    --border-label-pos=3 \
    --prompt=$'   ' \
    --pointer=$' ' \
    --header=$'  \033[38;5;244mtype a stream name\033[0m  \033[38;5;141menter\033[0m \033[38;5;244mcreate\033[0m  \033[38;5;141mesc\033[0m \033[38;5;244mcancel\033[0m\n' \
    --color='bg:#282a36,bg+:#44475a,fg:#f8f8f2,fg+:#f8f8f2' \
    --color='hl:#50fa7b,hl+:#50fa7b,info:#ffb86c' \
    --color='prompt:#bd93f9,pointer:#ff79c6,marker:#ff79c6' \
    --color='spinner:#ffb86c,header:#6272a4,border:#6272a4' \
    --color='label:#bd93f9' \
  | head -1 || true
)

# Trim surrounding whitespace; bail on empty (Esc or blank).
name="${name#"${name%%[![:space:]]*}"}"
name="${name%"${name##*[![:space:]]}"}"
[[ -z "$name" ]] && exit 0

session=$(session_name "$proj")
slug=$(slugify "$name")
logdir="${XDG_CACHE_HOME:-$HOME/.cache}/wst/logs"
mkdir -p "$logdir"
log="$logdir/$session-$slug.log"
: > "$log"; rm -f "$log.done"

# Run the creation fully detached (its own session via setsid) so hiding this
# popup with prefix+W never kills it. We run `wst new` under a PTY (python
# pty.spawn) so it sees a TTY and emits its pretty, collapsing ui_step output
# into the log — which we then replay with `tail`. stdin is /dev/null so the
# detached job is independent of this popup's lifetime. A sentinel signals done.
setsid bash -c '
  python3 -c "import pty,sys; sys.exit(pty.spawn(sys.argv[1:]))" \
    "$HOME/.local/bin/wst" new "$2" --project "$1" </dev/null >"$3" 2>&1
  rc=$?
  if [ "$rc" -eq 0 ]; then
    tmux display-message -t "$4" "wst: stream $2 ready" 2>/dev/null || true
  else
    tmux display-message -t "$4" "wst: stream $2 FAILED — see $3" 2>/dev/null || true
  fi
  : > "$3.done"
' _ "$proj" "$name" "$log" "$session" </dev/null >/dev/null 2>&1 &
disown 2>/dev/null || true

# Show live progress (tail replays the PTY output, spinner and all). The popup
# is modal, so keystrokes land here, not in tmux: read them raw and treat the
# prefix sequence (Ctrl-a then W) — or 'q' — as "hide". Hiding just exits this
# popup; the detached creation keeps running and opens the stream window itself.
printf '\n  creating stream \033[38;5;141m%s\033[0m in %s\n' "$name" "$proj"
printf '  \033[38;5;244mprefix+W (or q) hides this — creation keeps running\033[0m\n\n'
tail -n +1 -F "$log" 2>/dev/null &
tailpid=$!

stty_saved=$(stty -g 2>/dev/null || true)
[[ -n "$stty_saved" ]] && stty -echo -icanon min 1 time 0 2>/dev/null || true
hidden=false
while [[ ! -f "$log.done" ]]; do
  if IFS= read -rsn1 -t 0.2 k 2>/dev/null; then
    case "$k" in
      $'\x01')  # Ctrl-a (tmux prefix) — consume the next key, hide on W
        IFS= read -rsn1 -t 0.6 k2 2>/dev/null || true
        [[ "$k2" == [Ww] ]] && { hidden=true; break; } ;;
      q|Q) hidden=true; break ;;
    esac
  fi
done
kill "$tailpid" 2>/dev/null || true
tailpid=""
[[ -n "$stty_saved" ]] && stty "$stty_saved" 2>/dev/null || true
stty_saved=""

if ! $hidden; then
  sleep 0.3   # let tail flush the final lines
  printf '\n  \033[38;5;84mdone — closing\033[0m\n'
  sleep 1
fi
