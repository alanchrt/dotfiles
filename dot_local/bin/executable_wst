#!/usr/bin/env bash
# wst — workstream manager: parallel AI-coding streams via independent clones + devcontainers.
# See: dot_claude/CLAUDE.md "Workstream Workflow" and dot_local/share/wst/README.md.

set -euo pipefail

PROJECTS_ROOT="${WST_PROJECTS_ROOT:-$HOME/Projects}"
STATE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/wst"
PORTS_FILE="$STATE_DIR/ports.json"
OVERRIDES_DIR="$STATE_DIR/overrides"
DEFAULT_PORT_RANGE_LO=13000
DEFAULT_PORT_RANGE_HI=13999

mkdir -p "$STATE_DIR" "$OVERRIDES_DIR"

die() { printf 'wst: %s\n' "$*" >&2; exit 1; }
warn() { printf 'wst: %s\n' "$*" >&2; }
info() { printf '==> %s\n' "$*"; }

have() { command -v "$1" >/dev/null 2>&1; }

require_tool() {
  have "$1" || die "$1 not found on PATH. Install it first (see roles/$2/)."
}

# ---- project / stream resolution ----

slugify() {
  printf '%s' "$1" | tr '/' '-' | tr -c 'A-Za-z0-9._-' '-'
}

session_name() {
  printf '%s' "$1" | sed -r 's/\./_/g'
}

emacs_daemon_name() {
  printf 'wst-%s-%s' "$(slugify "$1")" "$(slugify "$2")"
}

# Resolve the project directory (~/Projects/<project>/) from cwd or --project flag.
# Echoes the project name on stdout.
resolve_project() {
  local explicit="${1:-}"
  if [[ -n "$explicit" ]]; then
    [[ -d "$PROJECTS_ROOT/$explicit" ]] || die "Project '$explicit' not found at $PROJECTS_ROOT/$explicit"
    printf '%s' "$explicit"
    return
  fi
  local pwd_abs
  pwd_abs=$(realpath "$PWD")
  local prefix="$PROJECTS_ROOT/"
  case "$pwd_abs" in
    "$prefix"*)
      local rel="${pwd_abs#"$prefix"}"
      printf '%s' "${rel%%/*}"
      ;;
    *)
      die "Not inside $PROJECTS_ROOT — pass --project <name> or cd into a project."
      ;;
  esac
}

canonical_dir() {
  printf '%s/%s/main' "$PROJECTS_ROOT" "$1"
}

stream_dir() {
  printf '%s/%s/%s' "$PROJECTS_ROOT" "$1" "$2"
}

# ---- port allocation ----

ports_init() {
  require_tool jq core
  [[ -s "$PORTS_FILE" ]] && return
  cat > "$PORTS_FILE" <<EOF
{"range": [$DEFAULT_PORT_RANGE_LO, $DEFAULT_PORT_RANGE_HI], "assignments": {}}
EOF
}

# Look up the port for a stream key (project/slug). Empty if unassigned.
port_get() {
  ports_init
  jq -r --arg k "$1" '.assignments[$k] // empty' "$PORTS_FILE"
}

# Allocate and persist the lowest-unused port for a stream key.
port_allocate() {
  ports_init
  local key="$1"
  local existing
  existing=$(port_get "$key")
  if [[ -n "$existing" ]]; then
    printf '%s' "$existing"
    return
  fi
  local lo hi
  lo=$(jq -r '.range[0]' "$PORTS_FILE")
  hi=$(jq -r '.range[1]' "$PORTS_FILE")
  local used
  used=$(jq -r '.assignments[]' "$PORTS_FILE" | sort -n)
  local p
  for ((p=lo; p<=hi; p++)); do
    if ! grep -qx "$p" <<<"$used"; then
      local tmp="$PORTS_FILE.tmp"
      jq --arg k "$key" --argjson v "$p" '.assignments[$k] = $v' "$PORTS_FILE" > "$tmp"
      mv "$tmp" "$PORTS_FILE"
      printf '%s' "$p"
      return
    fi
  done
  die "port range $lo-$hi exhausted (edit $PORTS_FILE to widen)"
}

port_free() {
  ports_init
  local tmp="$PORTS_FILE.tmp"
  jq --arg k "$1" 'del(.assignments[$k])' "$PORTS_FILE" > "$tmp"
  mv "$tmp" "$PORTS_FILE"
}

# ---- subcommand: clone ----

cmd_clone() {
  local url="${1:-}" name="${2:-}"
  [[ -n "$url" ]] || die "usage: wst clone <git-url> [project-name]"
  if [[ -z "$name" ]]; then
    name=$(basename "$url" .git)
  fi
  local target="$PROJECTS_ROOT/$name"
  [[ ! -e "$target" ]] || die "$target already exists"
  info "Cloning $url → $target/main"
  mkdir -p "$target"
  git clone "$url" "$target/main"
  info "Project laid out at $target/main"
  cat <<EOF

Next steps:
  cd $target/main
  wst new <branch> [--base main]   # create a stream
EOF
}

# ---- subcommand: new ----

cmd_new() {
  local branch="" base="" project=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --base)    base="$2"; shift 2 ;;
      --project) project="$2"; shift 2 ;;
      -*)        die "unknown flag: $1" ;;
      *)         [[ -z "$branch" ]] && branch="$1" || die "unexpected arg: $1"; shift ;;
    esac
  done
  [[ -n "$branch" ]] || die "usage: wst new <branch> [--base <base>] [--project <name>]"
  local proj; proj=$(resolve_project "$project")
  local canonical; canonical=$(canonical_dir "$proj")
  [[ -d "$canonical/.git" ]] || die "canonical '$canonical' is not a git repo (run: wst migrate)"

  local slug; slug=$(slugify "$branch")
  local target; target=$(stream_dir "$proj" "$slug")
  [[ ! -e "$target" ]] || die "stream dir $target already exists — use: wst attach $branch"

  # Resolve base if unset: origin/HEAD short name → fallback to current canonical branch
  if [[ -z "$base" ]]; then
    base=$(git -C "$canonical" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||' || true)
    [[ -n "$base" ]] || base=$(git -C "$canonical" branch --show-current)
  fi

  info "Cloning $canonical → $target (base: $base, branch: $branch)"
  git clone --local "$canonical" "$target"
  local origin_url
  origin_url=$(git -C "$canonical" remote get-url origin)
  git -C "$target" remote set-url origin "$origin_url"
  git -C "$target" fetch origin
  git -C "$target" checkout -B "$branch" "origin/$base"

  # Propagate Graphite enablement from canonical (rule symlink + git exclude).
  # The matching in-container `gt repo init` runs during provision_container.
  if [[ -L "$canonical/.claude/rules/graphite.md" ]]; then
    seed_graphite_rule "$target"
  fi

  local key="$proj/$slug"
  local host_port
  host_port=$(port_allocate "$key")
  info "Allocated host port $host_port for $key"

  info "Bringing up devcontainer..."
  WST_PROJECT="$proj" WST_BRANCH="$branch" WST_SLUG="$slug" \
    WST_HOST_PORT="$host_port" WST_TARGET="$target" \
    "$HOME/.local/bin/wst-container-up"

  info "Provisioning in-container tooling..."
  provision_container "$target"

  info "Creating tmux window..."
  tmux_create_window "$proj" "$branch" "$slug" "$target" "$host_port"

  cat <<EOF

Stream '$branch' ready.
  Workdir : $target
  Preview : http://localhost:$host_port/
  Attach  : wa $branch
EOF
}

# ---- subcommand: gtinit ----

# Mark a project as Graphite-enabled: symlink the shared graphite.md rule into
# the canonical and every existing stream's .claude/rules/, ignore the path via
# .git/info/exclude, and run `gt repo init` inside each running stream's
# container. Idempotent. Future streams pick up the rule automatically via
# cmd_new + provision_container.
cmd_gtinit() {
  local project=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      -*)        die "unknown flag: $1" ;;
      *)         die "unexpected arg: $1 (usage: wst gtinit [--project <name>])" ;;
    esac
  done

  local proj; proj=$(resolve_project "$project")
  local proj_root="$PROJECTS_ROOT/$proj"
  local canonical; canonical=$(canonical_dir "$proj")
  [[ -d "$canonical/.git" ]] || die "canonical '$canonical' is not a git repo"

  local rules_src="$HOME/.local/share/claude-rules/graphite.md"
  [[ -f "$rules_src" ]] || die "no rule at $rules_src — run: chezmoi apply"

  local -a clones=("$canonical")
  for sdir in "$proj_root"/*/; do
    [[ -d "$sdir/.git" ]] || continue
    [[ "$(basename "$sdir")" == "main" ]] && continue
    clones+=("${sdir%/}")
  done

  for clone in "${clones[@]}"; do
    seed_graphite_rule "$clone"
    info "Linked rule into $clone"
  done

  local trunk
  trunk=$(git -C "$canonical" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null \
    | sed 's|^origin/||' || true)
  [[ -n "$trunk" ]] || trunk=$(git -C "$canonical" branch --show-current)

  for sdir in "$proj_root"/*/; do
    [[ -d "$sdir/.git" ]] || continue
    local slug; slug=$(basename "$sdir")
    [[ "$slug" == "main" ]] && continue
    local sdir_clean="${sdir%/}"
    local cid
    cid=$(docker ps -q --filter "label=devcontainer.local_folder=$sdir_clean" 2>/dev/null || true)
    if [[ -z "$cid" ]]; then
      warn "skipping gt init in $slug — container not running (boot with: wa $slug)"
      continue
    fi
    info "Running gt repo init in $slug (trunk: $trunk)"
    "$HOME/.local/bin/wst-devcontainer-exec" "$sdir_clean" bash -lc \
      "command -v gt >/dev/null 2>&1 || npm install -g @withgraphite/graphite-cli >/dev/null 2>&1; gt repo init --trunk $trunk" \
      || warn "gt repo init reported errors for $slug (continuing)"
  done
}

# Seed .claude/rules/graphite.md as a symlink to the chezmoi-managed rule, and
# git-ignore the path. The symlink target is an absolute host path; combined
# with the matching bind-mount in wst-container-up, it resolves on host AND
# inside the container.
_add_to_git_exclude() {
  local clone="$1" rel="$2"
  local exclude_file="$clone/.git/info/exclude"
  if [[ ! -f "$exclude_file" ]]; then
    mkdir -p "$(dirname "$exclude_file")"
    : > "$exclude_file"
  fi
  grep -qxF "$rel" "$exclude_file" || echo "$rel" >> "$exclude_file"
}

seed_graphite_rule() {
  local clone="$1"

  # Claude: link the shared rule into .claude/rules/graphite.md
  local claude_src="$HOME/.local/share/claude-rules/graphite.md"
  if [[ -f "$claude_src" ]]; then
    mkdir -p "$clone/.claude/rules"
    ln -sfn "$claude_src" "$clone/.claude/rules/graphite.md"
    _add_to_git_exclude "$clone" ".claude/rules/graphite.md"
  fi

  # Codex: link the shared rule into AGENTS.override.md at the repo root.
  # Codex's AGENTS discovery walks cwd up to the git root checking
  # AGENTS.override.md first, then AGENTS.md — using .override.md keeps
  # the project's committed AGENTS.md (if any) untouched.
  local codex_src="$HOME/.local/share/codex-rules/graphite.md"
  if [[ -f "$codex_src" ]]; then
    ln -sfn "$codex_src" "$clone/AGENTS.override.md"
    _add_to_git_exclude "$clone" "AGENTS.override.md"
  fi
}

# ---- subcommand: attach ----

cmd_attach() {
  local branch="${1:-}"
  [[ -n "$branch" ]] || die "usage: wst attach <branch>"
  local proj; proj=$(resolve_project)
  local slug; slug=$(slugify "$branch")
  local target; target=$(stream_dir "$proj" "$slug")
  [[ -d "$target" ]] || die "stream '$branch' doesn't exist. Create with: wst new $branch"

  local session; session=$(session_name "$proj")
  if ! tmux has-session -t "$session" 2>/dev/null; then
    tmux new-session -d -s "$session" -c "$PROJECTS_ROOT/$proj"
  fi

  # Bring container up if stopped
  local container_id
  container_id=$(docker ps -q --filter "label=devcontainer.local_folder=$target" 2>/dev/null || true)
  if [[ -z "$container_id" ]]; then
    info "Container stopped — bringing it back up..."
    local key="$proj/$slug"
    local host_port; host_port=$(port_get "$key")
    [[ -n "$host_port" ]] || host_port=$(port_allocate "$key")
    WST_PROJECT="$proj" WST_BRANCH="$branch" WST_SLUG="$slug" \
      WST_HOST_PORT="$host_port" WST_TARGET="$target" \
      "$HOME/.local/bin/wst-container-up"
  fi

  # Window may not exist yet — create on first attach after a container restart
  if ! tmux list-windows -t "$session" -F '#{window_name}' 2>/dev/null | grep -qx "$slug"; then
    local key="$proj/$slug"
    local host_port; host_port=$(port_get "$key")
    tmux_create_window "$proj" "$branch" "$slug" "$target" "$host_port"
  fi

  if [[ -n "${TMUX:-}" ]]; then
    tmux select-window -t "$session:$slug"
  else
    tmux attach-session -t "$session" \; select-window -t "$session:$slug"
  fi
}

# ---- subcommand: preview ----

cmd_preview() {
  local branch="${1:-}"
  local port=""
  if [[ -z "$branch" ]]; then
    [[ -n "${TMUX:-}" ]] || die "preview needs <branch> outside tmux"
    port=$(tmux show-options -wqv @wst-port 2>/dev/null || true)
    [[ -n "$port" ]] || die "current tmux window is not a stream window (no @wst-port). Pass <branch>."
  else
    local proj; proj=$(resolve_project)
    local slug; slug=$(slugify "$branch")
    port=$(port_get "$proj/$slug")
    [[ -n "$port" ]] || die "no port allocated for $proj/$slug — did wst new run?"
  fi
  local url="http://localhost:$port/"
  printf '%s\n' "$url"
  have xdg-open && xdg-open "$url" >/dev/null 2>&1 || true
}

# ---- subcommand: ls ----

cmd_ls() {
  local all=false
  [[ "${1:-}" == "--all" ]] && all=true
  if $all; then
    for pdir in "$PROJECTS_ROOT"/*/; do
      [[ -d "$pdir" ]] || continue
      local pname; pname=$(basename "$pdir")
      _ls_project "$pname"
    done
  else
    local proj; proj=$(resolve_project)
    _ls_project "$proj"
  fi
}

_ls_project() {
  local proj="$1"
  local any=false
  for sdir in "$PROJECTS_ROOT/$proj"/*/; do
    [[ -d "$sdir/.git" ]] || continue
    local slug; slug=$(basename "$sdir")
    [[ "$slug" == "main" ]] && continue
    local key="$proj/$slug"
    local port; port=$(port_get "$key")
    local container_state="down"
    if [[ -n $(docker ps -q --filter "label=devcontainer.local_folder=$sdir" 2>/dev/null || true) ]]; then
      container_state="up"
    fi
    printf '%s/%s\t%s\tport:%s\n' "$proj" "$slug" "$container_state" "${port:-?}"
    any=true
  done
  $any || printf '(no streams in %s)\n' "$proj"
}

# ---- subcommand: rm ----

cmd_rm() {
  local branch="" force=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force|-f) force=true; shift ;;
      *)          [[ -z "$branch" ]] && branch="$1" || die "unexpected arg: $1"; shift ;;
    esac
  done
  [[ -n "$branch" ]] || die "usage: wst rm <branch> [--force]"
  local proj; proj=$(resolve_project)
  local slug; slug=$(slugify "$branch")
  local target; target=$(stream_dir "$proj" "$slug")
  [[ "$slug" != "main" ]] || die "refuse: 'main' is the canonical, not a stream"
  [[ -d "$target" ]] || { warn "$target does not exist (already removed?)"; return 0; }

  if ! $force; then
    local unpushed=0 unstaged=0
    if git -C "$target" rev-parse --abbrev-ref '@{upstream}' >/dev/null 2>&1; then
      unpushed=$(git -C "$target" log --oneline '@{upstream}..HEAD' 2>/dev/null | wc -l)
    else
      unpushed=$(git -C "$target" log --oneline 2>/dev/null | wc -l)
    fi
    unstaged=$(git -C "$target" status --porcelain 2>/dev/null | wc -l)
    if (( unpushed > 0 || unstaged > 0 )); then
      warn "stream has $unpushed unpushed / $unstaged unstaged changes — pass --force to remove anyway"
      return 1
    fi
  fi

  local cid
  cid=$(docker ps -aq --filter "label=devcontainer.local_folder=$target" 2>/dev/null || true)
  if [[ -n "$cid" ]]; then
    info "Removing container $cid"
    docker rm -f "$cid" >/dev/null
  fi

  local session; session=$(session_name "$proj")
  if tmux has-session -t "$session" 2>/dev/null \
       && tmux list-windows -t "$session" -F '#{window_name}' | grep -qx "$slug"; then
    tmux kill-window -t "$session:$slug" || true
  fi

  local emacs_daemon; emacs_daemon=$(emacs_daemon_name "$proj" "$slug")
  if emacsclient -s "$emacs_daemon" --eval t >/dev/null 2>&1; then
    info "Stopping Emacs daemon $emacs_daemon"
    emacsclient -s "$emacs_daemon" --eval '(kill-emacs)' >/dev/null 2>&1 || true
  fi

  info "Removing $target"
  rm -rf "$target"
  port_free "$proj/$slug"
  rm -f "$OVERRIDES_DIR/$proj-$slug.json"
  info "Stream '$branch' removed"
}

# ---- subcommand: doctor ----

cmd_doctor() {
  local ok=true
  printf 'Host prerequisites:\n'
  for t in docker devcontainer jq tmux git gh; do
    if have "$t"; then
      printf '  %-15s ok\n' "$t"
    else
      printf '  %-15s MISSING\n' "$t"
      ok=false
    fi
  done

  printf '\nADB bridge:\n'
  if have adb && adb -P 5037 devices >/dev/null 2>&1; then
    printf '  adb server on :5037 responding\n'
    local listening
    listening=$(ss -ltn 2>/dev/null | awk '$4 ~ /:5037$/ {print $4}' | head -1 || true)
    if [[ "$listening" == "0.0.0.0:5037" || "$listening" == "*:5037" ]]; then
      printf '  listening on all interfaces (containers can reach it)\n'
    else
      printf '  WARNING: adb may be bound to loopback only — start with: adb-start-bridged\n'
    fi
  else
    printf '  adb not running (start with: systemctl --user start adb-bridge)\n'
  fi

  printf '\nProjects layout (%s):\n' "$PROJECTS_ROOT"
  for d in "$PROJECTS_ROOT"/*/; do
    [[ -d "$d" ]] || continue
    local name; name=$(basename "$d")
    if [[ -d "$d/.git" ]]; then
      printf '  %-30s pre-migration layout (needs: wst migrate)\n' "$name"
      ok=false
    elif [[ -d "$d/main/.git" ]]; then
      printf '  %-30s migrated\n' "$name"
    fi
  done

  printf '\nPort assignments:\n'
  ports_init
  jq -r '.assignments | to_entries[] | "  " + .key + " → " + (.value|tostring)' "$PORTS_FILE"

  printf '\nOrphaned chrome volumes (wst-chrome-*):\n'
  docker volume ls --filter 'name=wst-chrome-' --format '  {{.Name}}' 2>/dev/null || true

  printf '\nwst-dev mega image:\n'
  local wst_dev="${WST_DEV_IMAGE:-wst-dev:latest}"
  if docker image inspect "$wst_dev" >/dev/null 2>&1; then
    local meta built age
    meta=$(docker run --rm --entrypoint cat "$wst_dev" /etc/wst/wst-dev.json 2>/dev/null || true)
    built=$(printf '%s' "$meta" | sed -n 's/.*"built_at": *"\([^"]*\)".*/\1/p')
    if [[ -n "$built" ]]; then
      age=$(( ($(date +%s) - $(date -d "$built" +%s)) / 86400 ))
      printf '  %s (built %s, %d days ago)\n' "$wst_dev" "$built" "$age"
      (( age > 30 )) && printf '  STALE — refresh: ansible-playbook ~/Projects/dotfiles/master/local.yml --tags wst-dev -e wst_dev_force_rebuild=true\n'
    else
      printf '  %s exists but metadata unreadable\n' "$wst_dev"
    fi
  else
    printf '  %s not built — run: ansible-playbook ~/Projects/dotfiles/master/local.yml --tags wst-dev\n' "$wst_dev"
    ok=false
  fi
  if docker volume inspect wst-chromium-profile >/dev/null 2>&1; then
    printf '  shared chromium profile volume: present\n'
  else
    printf '  shared chromium profile volume: missing (will be created on next ansible run)\n'
  fi

  $ok || exit 1
}

# ---- subcommand: migrate ----

cmd_migrate() {
  exec "$HOME/.local/bin/wst-migrate-canonical" "$@"
}

# ---- helpers ----

provision_container() {
  # wst-dev-entrypoint runs chezmoi apply, gh auth, mise install, gt repo
  # init, and ADB smoke test on container start. All that remains is
  # registering the Playwright MCP server with the user-level Claude
  # config — pointed at the persistent Chromium profile shared across
  # streams (see WST_BROWSER_PROFILE). Because ~/.claude/ is bind-mounted
  # from the host, this also "leaks" the config back to the host —
  # intentional: any wst-dev container reads the same mcp_servers.json.
  local target="$1"
  local provision_script
  provision_script=$(cat <<'SH'
set -e
mkdir -p "$HOME/.claude"
cat > "$HOME/.claude/mcp_servers.json" <<JSON
{
  "mcpServers": {
    "playwright": {
      "command": "bash",
      "args": [
        "-lc",
        "chrome=$(find /opt/playwright-browsers -path '*/chromium-*/chrome-linux*/chrome' -type f -executable 2>/dev/null | head -1); [ -n \"$chrome\" ] || { echo 'Claude Playwright MCP: Chromium not found under /opt/playwright-browsers' >&2; exit 1; }; exec playwright-mcp --executable-path \"$chrome\" --user-data-dir \"${WST_BROWSER_PROFILE:-/home/vscode/.config/chromium-wst}\""
      ]
    }
  }
}
JSON
SH
)
  "$HOME/.local/bin/wst-devcontainer-exec" "$target" bash -c "$provision_script" \
    || warn "post-up MCP registration had non-fatal errors (continuing)"
}

cmd_chrome() {
  # Open headed Chromium inside the current stream's container against the
  # shared persistent profile. Use this when Claude is driving the browser
  # via @playwright/mcp and asks you to complete SSO / MFA / a captcha —
  # see ~/.local/share/wst/README.md (Browser handoff workflow).
  #
  # Detect the stream via the tmux window option set by tmux_create_window.
  local proj branch target slug session
  proj=$(tmux show-options -wqv @wst-project 2>/dev/null || true)
  branch=$(tmux show-options -wqv @wst-stream 2>/dev/null || true)
  target=$(tmux show-options -wqv @wst-workdir 2>/dev/null || true)
  if [[ -z "$proj" || -z "$branch" || -z "$target" ]]; then
    die "not inside a wst stream tmux window (use \`wa <branch>\` first)"
  fi
  if [[ -z "${WAYLAND_DISPLAY:-}" ]]; then
    warn "WAYLAND_DISPLAY is empty on the host — headed Chromium will fail to connect"
  fi
  info "opening headed Chromium for stream $proj/$branch"
  # The Playwright-bundled chromium ships at a versioned path; resolve at
  # runtime so we don't pin a version here.
  "$HOME/.local/bin/wst-devcontainer-exec" "$target" bash -lc '
    chrome=$(find /opt/playwright-browsers -path "*/chromium-*/chrome-linux*/chrome" -type f -executable 2>/dev/null | head -1)
    [ -n "$chrome" ] || { echo "wst chrome: no chromium binary found under /opt/playwright-browsers" >&2; exit 1; }
    exec "$chrome" \
      --ozone-platform=wayland --enable-features=UseOzonePlatform \
      --user-data-dir="$WST_BROWSER_PROFILE" \
      --no-first-run --no-default-browser-check \
      "$@"
  ' bash "$@"
}

tmux_create_window() {
  local proj="$1" branch="$2" slug="$3" target="$4" host_port="$5"
  local session; session=$(session_name "$proj")
  if ! tmux has-session -t "$session" 2>/dev/null; then
    tmux new-session -d -s "$session" -c "$PROJECTS_ROOT/$proj"
  fi
  # Pass the command as the new-window argument so the pane's process IS the
  # devcontainer exec — avoids leaving the launch command visible in the
  # pane's scrollback. Drop straight into Codex (multi-session is via
  # `/agent` and `/resume` slash commands once inside); when it exits,
  # fall back to an interactive login shell so the pane stays usable.
  # Pane splits (wst-tmux-split) still open in zsh, so you can split for
  # shell work.
  tmux new-window -t "$session:" -n "$slug" -c "$target" \
    "$HOME/.local/bin/wst-devcontainer-exec '$target' zsh -l -c 'codex; exec zsh -l'"
  # 3-pane layout: agent (top-left ~60%), spare zsh (top-right ~40%),
  # git UI (bottom, full width, ~33% height). Set WST_PANES=1 to skip
  # the splits and keep the single-pane layout. The default Magit pane
  # runs on the host in a stream-specific Emacs daemon, so it edits host
  # paths without sharing buffers with other streams. Set
  # WST_GIT_PANE=lazygit to use lazygit in the devcontainer instead.
  if [[ "${WST_PANES:-}" != 1 ]]; then
    case "${WST_GIT_PANE:-magit}" in
      magit|emacs)
        local emacs_daemon; emacs_daemon=$(emacs_daemon_name "$proj" "$slug")
        tmux split-window -v -l 33% -t "$session:$slug" -c "$target" \
          "if ! emacsclient -s '$emacs_daemon' --eval t >/dev/null 2>&1; then emacs --daemon='$emacs_daemon'; fi; emacsclient -s '$emacs_daemon' --eval '(setq my/wst-next-stream-pane-dir \"$target\")' >/dev/null; emacsclient -t -s '$emacs_daemon' '$target'; exec zsh -l"
        ;;
      lazygit)
        tmux split-window -v -l 33% -t "$session:$slug" -c "$target" \
          "$HOME/.local/bin/wst-devcontainer-exec '$target' zsh -l -c 'lazygit; exec zsh -l'"
        ;;
      shell|zsh)
        tmux split-window -v -l 33% -t "$session:$slug" -c "$target" \
          "$HOME/.local/bin/wst-devcontainer-exec '$target' zsh -l"
        ;;
      *)
        die "unknown WST_GIT_PANE='${WST_GIT_PANE}' (expected: magit, lazygit, shell)"
        ;;
    esac
    # 2. Focus the top (codex) pane so the next split lands there.
    tmux select-pane -t "$session:$slug.0"
    # 3. Split the top pane horizontally for the spare zsh on the right.
    tmux split-window -h -l 40% -t "$session:$slug" -c "$target" \
      "$HOME/.local/bin/wst-devcontainer-exec '$target' zsh -l"
    # 4. Return focus to codex (top-left).
    tmux select-pane -t "$session:$slug.0"
  fi
  tmux set-option -w -t "$session:$slug" @wst-project "$proj"
  tmux set-option -w -t "$session:$slug" @wst-stream  "$branch"
  tmux set-option -w -t "$session:$slug" @wst-workdir "$target"
  tmux set-option -w -t "$session:$slug" @wst-port    "$host_port"
}

# ---- dispatch ----

usage() {
  cat <<'EOF'
wst — workstream manager

usage:
  wst clone <git-url> [project-name]                    clone repo into ~/Projects/<name>/main/  (alias: wcl)
  wst new <branch> [--base <base>] [--project <name>]   create stream
  wst attach <branch>                                   switch to / boot stream window           (alias: wa)
  wst preview [<branch>]                                open localhost:<port>/                   (alias: wp)
  wst ls [--all]                                        list streams                             (alias: wls)
  wst rm <branch> [--force]                             tear down stream
  wst gtinit [--project <name>]                         enable Graphite in canonical + all streams
  wst chrome [-- <url> ...]                             open headed Chromium for SSO/MFA handoff
  wst doctor                                            diagnostics
  wst migrate                                           one-shot canonical relocation

env:
  WST_PANES=1                                           single-pane layout (default: claude + lazygit + zsh)
EOF
}

case "${1:-}" in
  clone)   shift; cmd_clone "$@" ;;
  new)     shift; cmd_new "$@" ;;
  attach)  shift; cmd_attach "$@" ;;
  preview) shift; cmd_preview "$@" ;;
  ls)      shift; cmd_ls "$@" ;;
  rm)      shift; cmd_rm "$@" ;;
  gtinit)  shift; cmd_gtinit "$@" ;;
  chrome)  shift; cmd_chrome "$@" ;;
  doctor)  shift; cmd_doctor "$@" ;;
  migrate) shift; cmd_migrate "$@" ;;
  -h|--help|help|"") usage ;;
  *)       usage; exit 1 ;;
esac
