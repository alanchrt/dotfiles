#!/usr/bin/env bash
# wst — workstream manager: parallel AI-coding streams via independent clones + tmux.
# See: dot_codex/AGENTS.md "Workstream Workflow" and dot_local/share/wst/README.md.

set -euo pipefail

PROJECTS_ROOT="${WST_PROJECTS_ROOT:-$HOME/Projects}"
STATE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/wst"
PORTS_FILE="$STATE_DIR/ports.json"
OVERRIDES_DIR="$STATE_DIR/overrides"
DEFAULT_PORT_RANGE_LO=13000
DEFAULT_PORT_RANGE_HI=13999

mkdir -p "$STATE_DIR" "$OVERRIDES_DIR"

die() { printf 'wst: %s\n' "$*" >&2; exit 1; }
warn() { printf 'wst: %s\n' "$*" >&2; }
info() { printf '==> %s\n' "$*"; }
debug() {
  [[ -n "${WST_DEBUG:-}" ]] || return 0
  printf 'wst debug: %s\n' "$*" >&2
}

have() { command -v "$1" >/dev/null 2>&1; }

ui_color() {
  local code="$1"
  [[ -t 1 && -z "${NO_COLOR:-}" ]] && printf '\033[%sm' "$code"
  # Always succeed: callers like `ui_cyan` are invoked as bare statements, and a
  # non-zero return (when stdout isn't a TTY, so the printf is skipped) would
  # trip `set -e` and abort non-interactive runs (e.g. detached `wst new`).
  return 0
}

ui_reset() { ui_color 0; }
ui_dim() { ui_color 2; }
ui_green() { ui_color '1;32'; }
ui_red() { ui_color '1;31'; }
ui_cyan() { ui_color '1;36'; }

ui_step() {
  local label="$1"
  shift

  local log_dir="${WST_STEP_LOG_DIR:-}"
  if [[ -z "$log_dir" ]]; then
    log_dir=$(mktemp -d "${TMPDIR:-/tmp}/wst.XXXXXX")
    WST_STEP_LOG_DIR="$log_dir"
  fi
  mkdir -p "$log_dir"

  local log="$log_dir/$(slugify "$label").log"
  local interactive=false
  [[ -t 1 && -z "${WST_PLAIN_LOGS:-}" ]] && interactive=true

  if [[ -n "${WST_DEBUG:-}" ]]; then
    info "$label"
    debug "command: $*"
    "$@"
    return
  fi

  if ! $interactive; then
    info "$label"
    "$@"
    return
  fi

  local frames=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
  local i=0 pid status
  "$@" >"$log" 2>&1 &
  pid=$!

  while kill -0 "$pid" 2>/dev/null; do
    printf '\r\033[K  '
    ui_cyan
    printf '%s' "${frames[i % ${#frames[@]}]}"
    ui_reset
    printf ' %s' "$label"
    i=$((i + 1))
    sleep 0.12
  done

  if wait "$pid"; then
    printf '\r\033[K  '
    ui_green
    printf '✓'
    ui_reset
    printf ' %s\n' "$label"
    return 0
  else
    status=$?
  fi

  printf '\r\033[K  '
  ui_red
  printf '✕'
  ui_reset
  printf ' %s\n\n' "$label"
  printf 'stream: %s failed; full log follows from %s\n\n' "$label" "$log" >&2
  cat "$log" >&2
  return "$status"
}

require_tool() {
  have "$1" || die "$1 not found on PATH. Install it first (see roles/$2/)."
}

# ---- project / stream resolution ----

slugify() {
  printf '%s' "$1" | tr '/' '-' | tr -c 'A-Za-z0-9._-' '-'
}

session_name() {
  printf '%s' "$1" | sed -r 's/\./_/g'
}

emacs_daemon_name() {
  printf 'wst-%s-%s' "$(slugify "$1")" "$(slugify "$2")"
}

# Resolve the project directory (~/Projects/<project>/) from cwd or --project flag.
# Echoes the project name on stdout.
resolve_project() {
  local explicit="${1:-}"
  if [[ -n "$explicit" ]]; then
    [[ -d "$PROJECTS_ROOT/$explicit" ]] || die "Project '$explicit' not found at $PROJECTS_ROOT/$explicit"
    printf '%s' "$explicit"
    return
  fi
  local pwd_abs
  pwd_abs=$(realpath "$PWD")
  local prefix="$PROJECTS_ROOT/"
  case "$pwd_abs" in
    "$prefix"*)
      local rel="${pwd_abs#"$prefix"}"
      printf '%s' "${rel%%/*}"
      ;;
    *)
      die "Not inside $PROJECTS_ROOT — pass --project <name> or cd into a project."
      ;;
  esac
}

canonical_dir() {
  printf '%s/%s/main' "$PROJECTS_ROOT" "$1"
}

stream_dir() {
  printf '%s/%s/%s' "$PROJECTS_ROOT" "$1" "$2"
}

stream_runtime() {
  local target="$1"
  git -C "$target" config --get wst.runtime 2>/dev/null || printf 'host'
}

cdp_port_for_host_port() {
  local host_port="$1"
  if [[ "$host_port" =~ ^[0-9]+$ ]]; then
    printf '%s' "$((host_port + 10000))"
  else
    printf '9222'
  fi
}

set_stream_runtime() {
  local target="$1" runtime="$2"
  git -C "$target" config wst.runtime "$runtime"
}

ensure_devcontainer() {
  local proj="$1" branch="$2" slug="$3" target="$4" host_port="$5"
  local container_id
  container_id=$(docker ps -q --filter "label=devcontainer.local_folder=$target" 2>/dev/null || true)
  debug "container_id=${container_id:-<none>}"
  if [[ -z "$container_id" ]]; then
    ui_step "Start devcontainer on :$host_port" env \
      WST_PROJECT="$proj" WST_BRANCH="$branch" WST_SLUG="$slug" \
      WST_HOST_PORT="$host_port" WST_TARGET="$target" \
      "$HOME/.local/bin/wst-container-up"
  fi
}

stream_command() {
  local proj="$1" branch="$2" target="$3" host_port="$4" runtime="$5" inner="$6"
  local cdp_port; cdp_port=$(cdp_port_for_host_port "$host_port")
  if [[ "$runtime" == "devcontainer" ]]; then
    printf '%q %q zsh -l -c %q' \
      "$HOME/.local/bin/wst-devcontainer-exec" "$target" "$inner"
  else
    printf 'env WST_PROJECT=%q WST_STREAM=%q WST_PORT=%q WST_HOST_PORT=%q WST_CDP_PORT=%q WST_BROWSER_PROFILE=%q zsh -l -c %q' \
      "$proj" "$branch" "$host_port" "$host_port" "$cdp_port" "$HOME/.config/chromium-wst" "$inner"
  fi
}

# ---- port allocation ----

ports_init() {
  require_tool jq core
  [[ -s "$PORTS_FILE" ]] && return
  cat > "$PORTS_FILE" <<EOF
{"range": [$DEFAULT_PORT_RANGE_LO, $DEFAULT_PORT_RANGE_HI], "assignments": {}}
EOF
}

# Look up the port for a stream key (project/slug). Empty if unassigned.
port_get() {
  ports_init
  jq -r --arg k "$1" '.assignments[$k] // empty' "$PORTS_FILE"
}

# Allocate and persist the lowest-unused port for a stream key.
port_allocate() {
  ports_init
  local key="$1"
  local existing
  existing=$(port_get "$key")
  if [[ -n "$existing" ]]; then
    printf '%s' "$existing"
    return
  fi
  local lo hi
  lo=$(jq -r '.range[0]' "$PORTS_FILE")
  hi=$(jq -r '.range[1]' "$PORTS_FILE")
  local used
  used=$(jq -r '.assignments[]' "$PORTS_FILE" | sort -n)
  local p
  for ((p=lo; p<=hi; p++)); do
    if ! grep -qx "$p" <<<"$used"; then
      local tmp="$PORTS_FILE.tmp"
      jq --arg k "$key" --argjson v "$p" '.assignments[$k] = $v' "$PORTS_FILE" > "$tmp"
      mv "$tmp" "$PORTS_FILE"
      printf '%s' "$p"
      return
    fi
  done
  die "port range $lo-$hi exhausted (edit $PORTS_FILE to widen)"
}

port_free() {
  ports_init
  local tmp="$PORTS_FILE.tmp"
  jq --arg k "$1" 'del(.assignments[$k])' "$PORTS_FILE" > "$tmp"
  mv "$tmp" "$PORTS_FILE"
}

# ---- subcommand: clone ----

cmd_clone() {
  local url="${1:-}" name="${2:-}"
  [[ -n "$url" ]] || die "usage: wst clone <git-url> [project-name]"
  if [[ -z "$name" ]]; then
    name=$(basename "$url" .git)
  fi
  local target="$PROJECTS_ROOT/$name"
  [[ ! -e "$target" ]] || die "$target already exists"
  info "Cloning $url → $target/main"
  mkdir -p "$target"
  git clone "$url" "$target/main"
  info "Project laid out at $target/main"
  cat <<EOF

Next steps:
  cd $target/main
  wst new <branch> [--base main]   # create a stream
EOF
}

# ---- subcommand: new ----

cmd_new() {
  local branch="" base="" project="" runtime="host"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --base)    base="$2"; shift 2 ;;
      --project) project="$2"; shift 2 ;;
      --devcontainer) runtime="devcontainer"; shift ;;
      --debug)   WST_DEBUG=1; WST_PLAIN_LOGS=1; shift ;;
      -*)        die "unknown flag: $1" ;;
      *)         [[ -z "$branch" ]] && branch="$1" || die "unexpected arg: $1"; shift ;;
    esac
  done
  [[ -n "$branch" ]] || die "usage: wst new <branch> [--base <base>] [--project <name>] [--devcontainer] [--debug]"
  local proj; proj=$(resolve_project "$project")
  local canonical; canonical=$(canonical_dir "$proj")
  [[ -d "$canonical/.git" ]] || die "canonical '$canonical' is not a git repo (run: wst migrate)"

  local slug; slug=$(slugify "$branch")
  local target; target=$(stream_dir "$proj" "$slug")
  [[ ! -e "$target" ]] || die "stream dir $target already exists — use: wst attach $branch"

  # Resolve base if unset: origin/HEAD short name → fallback to current canonical branch
  if [[ -z "$base" ]]; then
    base=$(git -C "$canonical" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||' || true)
    [[ -n "$base" ]] || base=$(git -C "$canonical" branch --show-current)
  fi
  debug "project=$proj"
  debug "branch=$branch"
  debug "slug=$slug"
  debug "base=$base"
  debug "runtime=$runtime"
  debug "canonical=$canonical"
  debug "target=$target"

  local WST_STEP_LOG_DIR
  WST_STEP_LOG_DIR=$(mktemp -d "${TMPDIR:-/tmp}/wst-new.XXXXXX")
  debug "step_log_dir=$WST_STEP_LOG_DIR"

  ui_cyan
  printf 'Creating stream'
  ui_reset
  printf ' %s/%s\n\n' "$proj" "$branch"

  ui_step "Clone stream" git clone --local "$canonical" "$target"
  ui_step "Sync $base from origin (agent will branch as $branch)" cmd_new_checkout "$canonical" "$target" "$base" "$branch"
  set_stream_runtime "$target" "$runtime"

  # Propagate Graphite enablement from canonical (rule symlink + git exclude).
  # The matching `gt repo init` runs during provision_agent_tooling.
  if [[ -L "$canonical/.claude/rules/graphite.md" ]]; then
    seed_graphite_rule "$target"
  fi

  local key="$proj/$slug"
  local host_port
  host_port=$(port_allocate "$key")
  [[ ! -t 1 || -n "${WST_PLAIN_LOGS:-}" ]] && info "Allocated host port $host_port for $key"
  debug "host_port=$host_port"
  debug "override=$OVERRIDES_DIR/$proj-$slug.json"

  if [[ "$runtime" == "devcontainer" ]]; then
    ensure_devcontainer "$proj" "$branch" "$slug" "$target" "$host_port"
  fi

  ui_step "Provision agent tooling" provision_agent_tooling "$target" "$runtime"

  ui_step "Open tmux workspace" tmux_create_window "$proj" "$branch" "$slug" "$target" "$host_port" "$runtime"
  rm -rf "$WST_STEP_LOG_DIR"

  cat <<EOF

Stream '$branch' ready (on '$base', synced to origin).
  Workdir : $target
  Runtime : $runtime
  Preview : http://localhost:$host_port/
  Attach  : wa $branch
  Note    : agent creates branch '$branch' on first commit — commits on '$base' are blocked.
EOF
}

# The stream opens *on the trunk* (e.g. main) reset to origin/<base>, NOT on a
# pre-created feature branch. Rationale: a pre-created empty branch makes Graphite
# gripe, and we want the agent to create the branch when it starts work (the branch
# is then born with its first commit). The intended branch name is recorded in
# git config (wst.branch) and a pre-commit guard blocks commits made on the trunk.
cmd_new_checkout() {
  local canonical="$1" target="$2" base="$3" branch="$4"
  local origin_url
  origin_url=$(git -C "$canonical" remote get-url origin)
  git -C "$target" remote set-url origin "$origin_url"
  git -C "$target" fetch origin
  git -C "$target" checkout -B "$base" "origin/$base"
  git -C "$target" branch --set-upstream-to "origin/$base" "$base" 2>/dev/null || true
  git -C "$target" config wst.branch "$branch"   # branch the agent should create
  git -C "$target" config wst.trunk  "$base"     # trunk the commit guard protects
  install_trunk_commit_guard "$target"
}

# ---- subcommand: gtinit ----

# Mark a project as Graphite-enabled: symlink the shared graphite.md rule into
# the canonical and every existing stream's .claude/rules/, ignore the path via
# .git/info/exclude, and run `gt repo init` in each stream runtime.
# Idempotent. Future streams pick up the rule automatically via cmd_new +
# provision_agent_tooling.
cmd_gtinit() {
  local project=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      -*)        die "unknown flag: $1" ;;
      *)         die "unexpected arg: $1 (usage: wst gtinit [--project <name>])" ;;
    esac
  done

  local proj; proj=$(resolve_project "$project")
  local proj_root="$PROJECTS_ROOT/$proj"
  local canonical; canonical=$(canonical_dir "$proj")
  [[ -d "$canonical/.git" ]] || die "canonical '$canonical' is not a git repo"

  local rules_src="$HOME/.local/share/claude-rules/graphite.md"
  [[ -f "$rules_src" ]] || die "no rule at $rules_src — run: chezmoi apply"

  local -a clones=("$canonical")
  for sdir in "$proj_root"/*/; do
    [[ -d "$sdir/.git" ]] || continue
    [[ "$(basename "$sdir")" == "main" ]] && continue
    clones+=("${sdir%/}")
  done

  for clone in "${clones[@]}"; do
    seed_graphite_rule "$clone"
    info "Linked rule into $clone"
  done

  local trunk
  trunk=$(git -C "$canonical" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null \
    | sed 's|^origin/||' || true)
  [[ -n "$trunk" ]] || trunk=$(git -C "$canonical" branch --show-current)

  for sdir in "$proj_root"/*/; do
    [[ -d "$sdir/.git" ]] || continue
    local slug; slug=$(basename "$sdir")
    [[ "$slug" == "main" ]] && continue
    local sdir_clean="${sdir%/}"
    local runtime
    runtime=$(stream_runtime "$sdir_clean")
    if [[ "$runtime" == "devcontainer" ]]; then
      local cid
      cid=$(docker ps -q --filter "label=devcontainer.local_folder=$sdir_clean" 2>/dev/null || true)
      if [[ -z "$cid" ]]; then
        warn "skipping gt init in $slug — devcontainer not running (boot with: wa $slug --devcontainer)"
        continue
      fi
      info "Running gt repo init in $slug devcontainer (trunk: $trunk)"
      "$HOME/.local/bin/wst-devcontainer-exec" "$sdir_clean" bash -lc \
        "command -v gt >/dev/null 2>&1 || npm install -g @withgraphite/graphite-cli >/dev/null 2>&1; gt repo init --trunk $trunk" \
        || warn "gt repo init reported errors for $slug (continuing)"
    else
      info "Running gt repo init in $slug on host (trunk: $trunk)"
      (
        cd "$sdir_clean"
        command -v gt >/dev/null 2>&1 || npm install -g @withgraphite/graphite-cli >/dev/null 2>&1
        gt repo init --trunk "$trunk"
      ) || warn "gt repo init reported errors for $slug (continuing)"
    fi
  done
}

# Seed agent Graphite rule files as symlinks to the shared AGENTS override
# rule, and git-ignore the paths. The symlink target is an absolute host path;
# The symlink target is an absolute host path. Devcontainer streams bind-mount
# the same path so the link resolves there too.
_add_to_git_exclude() {
  local clone="$1" rel="$2"
  local exclude_file="$clone/.git/info/exclude"
  if [[ ! -f "$exclude_file" ]]; then
    mkdir -p "$(dirname "$exclude_file")"
    : > "$exclude_file"
  fi
  grep -qxF "$rel" "$exclude_file" || echo "$rel" >> "$exclude_file"
}

seed_graphite_rule() {
  local clone="$1"

  local codex_src="$HOME/.local/share/codex-rules/graphite.md"

  # Claude Code still discovers project-specific rule files under .claude/,
  # but the maintained content is the same AGENTS override used by Codex.
  if [[ -f "$codex_src" ]]; then
    mkdir -p "$clone/.claude/rules"
    ln -sfn "$codex_src" "$clone/.claude/rules/graphite.md"
    _add_to_git_exclude "$clone" ".claude/rules/graphite.md"
  fi

  # Codex: link the shared rule into AGENTS.override.md at the repo root.
  # Codex's AGENTS discovery walks cwd up to the git root checking
  # AGENTS.override.md first, then AGENTS.md — using .override.md keeps
  # the project's committed AGENTS.md (if any) untouched.
  if [[ -f "$codex_src" ]]; then
    ln -sfn "$codex_src" "$clone/AGENTS.override.md"
    _add_to_git_exclude "$clone" "AGENTS.override.md"
  fi
}

# Install a pre-commit hook that refuses commits made while HEAD is the trunk.
# Streams open on the trunk (see cmd_new_checkout); this enforces that agents
# branch before committing rather than landing work on main/master. The hook is
# local to the stream's .git (git clone --local does not copy hooks), so writing
# it is an idempotent overwrite. `gt create` switches to the new branch before
# committing, so Graphite passes; `--no-verify` remains an escape hatch.
install_trunk_commit_guard() {
  local target="$1"
  local hook="$target/.git/hooks/pre-commit"
  mkdir -p "$target/.git/hooks"
  cat > "$hook" <<'HOOK'
#!/usr/bin/env bash
# Managed by wst — blocks commits on the trunk so streams branch first.
cur=$(git symbolic-ref --short HEAD 2>/dev/null) || exit 0
trunk=$(git config wst.trunk 2>/dev/null || echo main)
case "$cur" in
  "$trunk"|main|master)
    s=$(git config wst.branch 2>/dev/null); : "${s:=${WST_STREAM:-my-feature}}"
    echo "wst: refusing to commit on trunk '$cur'." >&2
    echo "Create a feature branch first:" >&2
    echo "    git switch -c $s        # or: gt create -m \"...\"  (Graphite)" >&2
    exit 1 ;;
esac
exit 0
HOOK
  chmod +x "$hook"
}

# ---- subcommand: attach ----

cmd_attach() {
  local branch="" force_runtime=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --devcontainer) force_runtime="devcontainer"; shift ;;
      --debug) WST_DEBUG=1; WST_PLAIN_LOGS=1; shift ;;
      -*)      die "unknown flag: $1" ;;
      *)       [[ -z "$branch" ]] && branch="$1" || die "unexpected arg: $1"; shift ;;
    esac
  done
  [[ -n "$branch" ]] || die "usage: wst attach <branch> [--devcontainer] [--debug]"
  local proj; proj=$(resolve_project)
  local slug; slug=$(slugify "$branch")
  local target; target=$(stream_dir "$proj" "$slug")
  [[ -d "$target" ]] || die "stream '$branch' doesn't exist. Create with: wst new $branch"
  debug "project=$proj"
  debug "branch=$branch"
  debug "slug=$slug"
  debug "target=$target"
  if [[ -n "$force_runtime" ]]; then
    set_stream_runtime "$target" "$force_runtime"
  fi
  local runtime; runtime=$(stream_runtime "$target")
  debug "runtime=$runtime"

  # Self-heal: ensure pre-existing streams gain the trunk commit guard. Resolve
  # the trunk if it was never recorded (older streams), then (re)install the hook.
  if [[ -d "$target/.git" ]]; then
    if [[ -z "$(git -C "$target" config wst.trunk 2>/dev/null || true)" ]]; then
      local trunk
      trunk=$(git -C "$target" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||' || true)
      [[ -n "$trunk" ]] || trunk=$(git -C "$target" branch --show-current)
      [[ -n "$trunk" ]] && git -C "$target" config wst.trunk "$trunk"
    fi
    [[ -z "$(git -C "$target" config wst.branch 2>/dev/null || true)" ]] && \
      git -C "$target" config wst.branch "$branch"
    install_trunk_commit_guard "$target"
  fi

  local session; session=$(session_name "$proj")
  debug "tmux_session=$session"
  if ! tmux has-session -t "$session" 2>/dev/null; then
    debug "creating tmux session $session"
    tmux new-session -d -s "$session" -c "$PROJECTS_ROOT/$proj"
  fi

  if [[ "$runtime" == "devcontainer" ]]; then
    info "Ensuring devcontainer is running..."
    local key="$proj/$slug"
    local host_port; host_port=$(port_get "$key")
    [[ -n "$host_port" ]] || host_port=$(port_allocate "$key")
    debug "host_port=$host_port"
    ensure_devcontainer "$proj" "$branch" "$slug" "$target" "$host_port"
  fi

  if [[ -n "$force_runtime" ]] \
       && tmux list-windows -t "$session" -F '#{window_name}' 2>/dev/null | grep -qx "$slug"; then
    local current_runtime
    current_runtime=$(tmux show-options -wqv -t "$session:$slug" @wst-runtime 2>/dev/null || true)
    current_runtime="${current_runtime:-host}"
    if [[ "$current_runtime" != "$runtime" ]]; then
      debug "recreating tmux window $session:$slug for runtime $runtime"
      tmux kill-window -t "$session:$slug"
    fi
  fi

  # Window may not exist yet — create on first attach after a stream is closed.
  if ! tmux list-windows -t "$session" -F '#{window_name}' 2>/dev/null | grep -qx "$slug"; then
    debug "tmux window $session:$slug missing; creating"
    local key="$proj/$slug"
    local host_port; host_port=$(port_get "$key")
    [[ -n "$host_port" ]] || host_port=$(port_allocate "$key")
    tmux_create_window "$proj" "$branch" "$slug" "$target" "$host_port" "$runtime"
  else
    debug "tmux window $session:$slug exists"
    local key="$proj/$slug"
    local host_port; host_port=$(port_get "$key")
    [[ -n "$host_port" ]] || host_port=$(port_allocate "$key")
    tmux set-option -w -t "$session:$slug" @wst-runtime "$runtime"
    tmux set-option -w -t "$session:$slug" @wst-port "$host_port"
    tmux set-option -w -t "$session:$slug" @wst-cdp-port "$(cdp_port_for_host_port "$host_port")"
  fi

  if [[ -n "${TMUX:-}" ]]; then
    tmux select-window -t "$session:$slug"
  else
    tmux attach-session -t "$session" \; select-window -t "$session:$slug"
  fi
}

# ---- subcommand: preview ----

cmd_preview() {
  local branch="${1:-}"
  local port=""
  if [[ -z "$branch" ]]; then
    [[ -n "${TMUX:-}" ]] || die "preview needs <branch> outside tmux"
    port=$(tmux show-options -wqv @wst-port 2>/dev/null || true)
    [[ -n "$port" ]] || die "current tmux window is not a stream window (no @wst-port). Pass <branch>."
  else
    local proj; proj=$(resolve_project)
    local slug; slug=$(slugify "$branch")
    port=$(port_get "$proj/$slug")
    [[ -n "$port" ]] || die "no port allocated for $proj/$slug — did wst new run?"
  fi
  local url="http://localhost:$port/"
  printf '%s\n' "$url"
  have xdg-open && xdg-open "$url" >/dev/null 2>&1 || true
}

# ---- subcommand: ls ----

cmd_ls() {
  local all=false
  [[ "${1:-}" == "--all" ]] && all=true
  if $all; then
    for pdir in "$PROJECTS_ROOT"/*/; do
      [[ -d "$pdir" ]] || continue
      local pname; pname=$(basename "$pdir")
      _ls_project "$pname"
    done
  else
    local proj; proj=$(resolve_project)
    _ls_project "$proj"
  fi
}

_ls_project() {
  local proj="$1"
  local any=false
  for sdir in "$PROJECTS_ROOT/$proj"/*/; do
    [[ -d "$sdir/.git" ]] || continue
    local slug; slug=$(basename "$sdir")
    [[ "$slug" == "main" ]] && continue
    local key="$proj/$slug"
    local port; port=$(port_get "$key")
    local runtime; runtime=$(stream_runtime "${sdir%/}")
    local state="$runtime"
    if [[ "$runtime" == "devcontainer" ]]; then
      state="devcontainer:down"
      if [[ -n $(docker ps -q --filter "label=devcontainer.local_folder=${sdir%/}" 2>/dev/null || true) ]]; then
        state="devcontainer:up"
      fi
    fi
    printf '%s/%s\t%s\tport:%s\n' "$proj" "$slug" "$state" "${port:-?}"
    any=true
  done
  $any || printf '(no streams in %s)\n' "$proj"
}

# ---- subcommand: rm ----

cmd_rm() {
  local branch="" force=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force|-f) force=true; shift ;;
      *)          [[ -z "$branch" ]] && branch="$1" || die "unexpected arg: $1"; shift ;;
    esac
  done
  [[ -n "$branch" ]] || die "usage: wst rm <branch> [--force]"
  local proj; proj=$(resolve_project)
  local slug; slug=$(slugify "$branch")
  local target; target=$(stream_dir "$proj" "$slug")
  [[ "$slug" != "main" ]] || die "refuse: 'main' is the canonical, not a stream"
  [[ -d "$target" ]] || { warn "$target does not exist (already removed?)"; return 0; }

  if ! $force; then
    local unpushed=0 unstaged=0
    if git -C "$target" rev-parse --abbrev-ref '@{upstream}' >/dev/null 2>&1; then
      unpushed=$(git -C "$target" log --oneline '@{upstream}..HEAD' 2>/dev/null | wc -l)
    else
      unpushed=$(git -C "$target" log --oneline 2>/dev/null | wc -l)
    fi
    unstaged=$(git -C "$target" status --porcelain 2>/dev/null | wc -l)
    if (( unpushed > 0 || unstaged > 0 )); then
      warn "stream has $unpushed unpushed / $unstaged unstaged changes — pass --force to remove anyway"
      return 1
    fi
  fi

  local cid
  cid=$(docker ps -aq --filter "label=devcontainer.local_folder=$target" 2>/dev/null || true)

  local session; session=$(session_name "$proj")

  local emacs_daemon; emacs_daemon=$(emacs_daemon_name "$proj" "$slug")

  local WST_STEP_LOG_DIR
  WST_STEP_LOG_DIR=$(mktemp -d "${TMPDIR:-/tmp}/wst-rm.XXXXXX")

  ui_cyan
  printf 'Removing stream'
  ui_reset
  printf ' %s/%s\n\n' "$proj" "$branch"

  [[ -z "$cid" ]] || ui_step "Remove devcontainer" cmd_rm_container "$cid"
  ui_step "Close tmux workspace" cmd_rm_tmux_window "$session" "$slug"
  ui_step "Stop Emacs pane" cmd_rm_emacs "$emacs_daemon"
  ui_step "Remove stream files" rm -rf "$target"
  ui_step "Release port and cache" cmd_rm_state "$proj/$slug" "$OVERRIDES_DIR/$proj-$slug.json"
  rm -rf "$WST_STEP_LOG_DIR"

  ui_green
  printf '✓'
  ui_reset
  printf ' Removed %s/%s\n' "$proj" "$branch"
}

cmd_rm_container() {
  docker rm -f "$1" >/dev/null
}

cmd_rm_tmux_window() {
  local session="$1" slug="$2"
  if tmux has-session -t "$session" 2>/dev/null \
       && tmux list-windows -t "$session" -F '#{window_name}' | grep -qx "$slug"; then
    tmux kill-window -t "$session:$slug"
  fi
}

cmd_rm_emacs() {
  local emacs_daemon="$1"
  if emacsclient -s "$emacs_daemon" --eval t >/dev/null 2>&1; then
    emacsclient -s "$emacs_daemon" --eval '(kill-emacs)' >/dev/null
  fi
}

cmd_rm_state() {
  local key="$1" override="$2"
  port_free "$key"
  rm -f "$override"
}

# ---- subcommand: doctor ----

cmd_doctor() {
  local ok=true
  printf 'Host prerequisites:\n'
  for t in jq tmux git gh; do
    if have "$t"; then
      printf '  %-15s ok\n' "$t"
    else
      printf '  %-15s MISSING\n' "$t"
      ok=false
    fi
  done

  printf '\nDevcontainer prerequisites (only needed for wst --devcontainer):\n'
  for t in docker devcontainer; do
    if have "$t"; then
      printf '  %-15s ok\n' "$t"
    else
      printf '  %-15s optional missing\n' "$t"
    fi
  done

  printf '\nADB bridge:\n'
  if have adb && adb -P 5037 devices >/dev/null 2>&1; then
    printf '  adb server on :5037 responding\n'
    local listening
    listening=$(ss -ltn 2>/dev/null | awk '$4 ~ /:5037$/ {print $4}' | head -1 || true)
    if [[ "$listening" == "0.0.0.0:5037" || "$listening" == "*:5037" ]]; then
      printf '  listening on all interfaces (devcontainers can reach it)\n'
    else
      printf '  WARNING: adb may be bound to loopback only — start with: adb-start-bridged\n'
    fi
  else
    printf '  adb not running (start with: systemctl --user start adb-bridge)\n'
  fi

  printf '\nProjects layout (%s):\n' "$PROJECTS_ROOT"
  for d in "$PROJECTS_ROOT"/*/; do
    [[ -d "$d" ]] || continue
    local name; name=$(basename "$d")
    if [[ -d "$d/.git" ]]; then
      printf '  %-30s pre-migration layout (needs: wst migrate)\n' "$name"
      ok=false
    elif [[ -d "$d/main/.git" ]]; then
      printf '  %-30s migrated\n' "$name"
    fi
  done

  printf '\nPort assignments:\n'
  ports_init
  jq -r '.assignments | to_entries[] | "  " + .key + " → " + (.value|tostring)' "$PORTS_FILE"

  if have docker; then
    printf '\nOrphaned chrome volumes (wst-chrome-*):\n'
    docker volume ls --filter 'name=wst-chrome-' --format '  {{.Name}}' 2>/dev/null || true

    printf '\nwst-dev mega image (only needed for --devcontainer):\n'
    local wst_dev="${WST_DEV_IMAGE:-wst-dev:latest}"
    if docker image inspect "$wst_dev" >/dev/null 2>&1; then
      local meta built age
      meta=$(docker run --rm --entrypoint cat "$wst_dev" /etc/wst/wst-dev.json 2>/dev/null || true)
      built=$(printf '%s' "$meta" | sed -n 's/.*"built_at": *"\([^"]*\)".*/\1/p')
      if [[ -n "$built" ]]; then
        age=$(( ($(date +%s) - $(date -d "$built" +%s)) / 86400 ))
        printf '  %s (built %s, %d days ago)\n' "$wst_dev" "$built" "$age"
        (( age > 30 )) && printf '  STALE — refresh: ansible-playbook -i ~/Projects/dotfiles/master/hosts ~/Projects/dotfiles/master/local.yml --tags wst-dev -e wst_dev_force_rebuild=true\n'
      else
        printf '  %s exists but metadata unreadable\n' "$wst_dev"
      fi
    else
      printf '  %s not built — run only if you use --devcontainer: ansible-playbook -i ~/Projects/dotfiles/master/hosts ~/Projects/dotfiles/master/local.yml --tags wst-dev\n' "$wst_dev"
    fi
    if docker volume inspect wst-chromium-profile >/dev/null 2>&1; then
      printf '  shared chromium profile volume: present\n'
    else
      printf '  shared chromium profile volume: missing (will be created on next ansible run)\n'
    fi
  fi

  $ok || exit 1
}

# ---- subcommand: migrate ----

cmd_migrate() {
  exec "$HOME/.local/bin/wst-migrate-canonical" "$@"
}

# ---- helpers ----

provision_agent_tooling() {
  local target="$1" runtime="$2"
  if [[ "$runtime" == "devcontainer" ]]; then
    provision_container "$target"
  else
    provision_host "$target"
  fi
}

provision_host() {
  local target="$1"
  mkdir -p "$HOME/.config/chromium-wst"
  write_claude_mcp_config "$HOME"
  if command -v zsh >/dev/null 2>&1; then
    (cd "$target" && timeout 90 zsh -lic 'true' >/dev/null 2>&1) || true
  fi
}

write_claude_mcp_config() {
  local home_dir="$1"
  mkdir -p "$home_dir/.claude"
  cat > "$home_dir/.claude/mcp_servers.json" <<'JSON'
{
  "mcpServers": {
    "chrome-devtools": {
      "command": "bash",
      "args": [
        "-lc",
        "exec npx -y chrome-devtools-mcp@latest --browser-url \"http://127.0.0.1:${WST_CDP_PORT:-9222}\" --no-usage-statistics"
      ]
    },
    "typescript": {
      "command": "npx",
      "args": ["-y", "ts-mcp-server"]
    }
  }
}
JSON
}

provision_container() {
  # wst-dev-entrypoint runs chezmoi apply, gh auth, mise install, gt repo
  # init, and ADB smoke test on container start. WST writes the user-level
  # Claude MCP config on the host before entering the devcontainer; ~/.claude/
  # is bind-mounted so devcontainer streams read the same config.
  local target="$1"
  local provision_script
  provision_script=$(cat <<'SH'
set -e
# Prime the prompt helper during provisioning so fresh terminal panes don't
# show powerlevel10k's first-run gitstatusd download message.
if command -v zsh >/dev/null 2>&1; then
  timeout 90 zsh -lic 'true' >/dev/null 2>&1 || true
fi
SH
)
  write_claude_mcp_config "$HOME"
  "$HOME/.local/bin/wst-devcontainer-exec" "$target" bash -c "$provision_script" \
    || warn "post-up MCP registration had non-fatal errors (continuing)"
}

cmd_chrome() {
  # Open headed Chromium for the current stream against the shared persistent
  # profile. Use this when Codex/Claude needs a Chrome DevTools MCP target or
  # asks you to complete SSO / MFA / a captcha —
  # see ~/.local/share/wst/README.md (Browser handoff workflow).
  #
  # Detect the stream via the tmux window option set by tmux_create_window.
  local proj branch target slug session
  proj=$(tmux show-options -wqv @wst-project 2>/dev/null || true)
  branch=$(tmux show-options -wqv @wst-stream 2>/dev/null || true)
  target=$(tmux show-options -wqv @wst-workdir 2>/dev/null || true)
  if [[ -z "$proj" || -z "$branch" || -z "$target" ]]; then
    die "not inside a wst stream tmux window (use \`wa <branch>\` first)"
  fi
  if [[ -z "${WAYLAND_DISPLAY:-}" ]]; then
    warn "WAYLAND_DISPLAY is empty on the host — headed Chromium will fail to connect"
  fi
  local runtime; runtime=$(stream_runtime "$target")
  local port cdp_port
  port=$(tmux show-options -wqv @wst-port 2>/dev/null || true)
  cdp_port=$(tmux show-options -wqv @wst-cdp-port 2>/dev/null || true)
  cdp_port="${cdp_port:-$(cdp_port_for_host_port "$port")}"
  info "opening headed Chromium for stream $proj/$branch ($runtime, CDP :$cdp_port)"
  if [[ "$runtime" == "devcontainer" ]]; then
    # Chromium is installed under the Playwright browser cache path; resolve at
    # runtime so we don't pin a version here.
    "$HOME/.local/bin/wst-devcontainer-exec" "$target" bash -lc '
      chrome=$(find /opt/playwright-browsers -path "*/chromium-*/chrome-linux*/chrome" -type f -executable 2>/dev/null | head -1)
      [ -n "$chrome" ] || { echo "wst chrome: no chromium binary found under /opt/playwright-browsers" >&2; exit 1; }
      exec "$chrome" \
        --ozone-platform=wayland --enable-features=UseOzonePlatform \
        --remote-debugging-port="${WST_CDP_PORT:-9222}" \
        --user-data-dir="$WST_BROWSER_PROFILE" \
        --no-first-run --no-default-browser-check \
        "$@"
    ' bash "$@"
  else
    local chrome=""
    for candidate in chromium chromium-browser google-chrome google-chrome-stable; do
      if command -v "$candidate" >/dev/null 2>&1; then
        chrome=$(command -v "$candidate")
        break
      fi
    done
    [[ -n "$chrome" ]] || die "no host Chromium/Chrome binary found on PATH"
    exec "$chrome" \
      --remote-debugging-port="$cdp_port" \
      --user-data-dir="$HOME/.config/chromium-wst" \
      --no-first-run --no-default-browser-check \
      "$@"
  fi
}

tmux_create_window() {
  local proj="$1" branch="$2" slug="$3" target="$4" host_port="$5" runtime="${6:-host}"
  local cdp_port; cdp_port=$(cdp_port_for_host_port "$host_port")
  local session; session=$(session_name "$proj")
  if ! tmux has-session -t "$session" 2>/dev/null; then
    tmux new-session -d -s "$session" -c "$PROJECTS_ROOT/$proj"
  fi
  # Pass the command as the new-window argument so the pane's process IS the
  # stream command — avoids leaving the launch command visible in scrollback.
  # Drop straight into Codex; when it exits, fall back to an interactive login
  # shell so the pane stays usable. Pane splits (wst-tmux-split) still open in
  # zsh, so you can split for shell work.
  local agent_pane=""
  local git_pane=""
  local shell_pane=""
  local agent_command
  agent_command=$(stream_command "$proj" "$branch" "$target" "$host_port" "$runtime" 'codex; exec zsh -l')
  agent_pane=$(tmux new-window -P -F '#{pane_id}' -t "$session:" -n "$slug" -c "$target" \
    "$agent_command")
  # 3-pane layout: agent (top-left ~60%), spare zsh (top-right ~40%),
  # git UI (bottom, full width, ~33% height). Set WST_PANES=1 to skip
  # the splits and keep the single-pane layout. The default Magit pane
  # runs on the host in a stream-specific Emacs daemon, so it edits host
  # paths without sharing buffers with other streams. Set
  # WST_GIT_PANE=lazygit to use lazygit in the active stream runtime instead.
  if [[ "${WST_PANES:-}" != 1 ]]; then
    case "${WST_GIT_PANE:-magit}" in
      magit|emacs)
        local emacs_daemon; emacs_daemon=$(emacs_daemon_name "$proj" "$slug")
        local emacs_command
        printf -v emacs_command '%q %q %q %q' \
          "$HOME/.local/bin/wst-emacs-pane" "$emacs_daemon" "$target" "$proj/$branch"
        git_pane=$(tmux split-window -P -F '#{pane_id}' -v -l 33% -t "$session:$slug" -c "$target" \
          "$emacs_command")
        ;;
      lazygit)
        local lazygit_command
        lazygit_command=$(stream_command "$proj" "$branch" "$target" "$host_port" "$runtime" 'lazygit; exec zsh -l')
        git_pane=$(tmux split-window -P -F '#{pane_id}' -v -l 33% -t "$session:$slug" -c "$target" \
          "$lazygit_command")
        ;;
      shell|zsh)
        local git_shell_command
        git_shell_command=$(stream_command "$proj" "$branch" "$target" "$host_port" "$runtime" 'exec zsh -l')
        git_pane=$(tmux split-window -P -F '#{pane_id}' -v -l 33% -t "$session:$slug" -c "$target" \
          "$git_shell_command")
        ;;
      *)
        die "unknown WST_GIT_PANE='${WST_GIT_PANE}' (expected: magit, lazygit, shell)"
        ;;
    esac
    # 2. Focus the top agent pane so the next split lands there.
    tmux select-pane -t "$session:$slug.0"
    # 3. Split the top pane horizontally for the spare zsh on the right.
    local shell_command
    shell_command=$(stream_command "$proj" "$branch" "$target" "$host_port" "$runtime" 'exec zsh -l')
    shell_pane=$(tmux split-window -P -F '#{pane_id}' -h -l 40% -t "$session:$slug" -c "$target" \
      "$shell_command")
    # 4. Return focus to the agent (top-left).
    tmux select-pane -t "$session:$slug.0"
  fi
  tmux set-option -w -t "$session:$slug" @wst-project "$proj"
  tmux set-option -w -t "$session:$slug" @wst-stream  "$branch"
  tmux set-option -w -t "$session:$slug" @wst-workdir "$target"
  tmux set-option -w -t "$session:$slug" @wst-port    "$host_port"
  tmux set-option -w -t "$session:$slug" @wst-cdp-port "$cdp_port"
  tmux set-option -w -t "$session:$slug" @wst-runtime "$runtime"
  tmux set-option -w -t "$session:$slug" @wst-agent-pane "$agent_pane"
  tmux set-option -w -t "$session:$slug" @wst-codex-pane "$agent_pane"
  tmux set-option -w -t "$session:$slug" @wst-git-pane   "$git_pane"
  tmux set-option -w -t "$session:$slug" @wst-shell-pane "$shell_pane"
}

# ---- dispatch ----

usage() {
  cat <<'EOF'
wst — workstream manager

usage:
  wst clone <git-url> [project-name]                    clone repo into ~/Projects/<name>/main/  (alias: wcl)
  wst new <branch> [--base <base>] [--project <name>] [--devcontainer] [--debug]
                                                          create stream
  wst attach <branch> [--devcontainer] [--debug]        switch to stream window                  (alias: wa)
  wst preview [<branch>]                                open localhost:<port>/                   (alias: wp)
  wst ls [--all]                                        list streams                             (alias: wls)
  wst rm <branch> [--force]                             tear down stream
  wst gtinit [--project <name>]                         enable Graphite in canonical + all streams
  wst chrome [-- <url> ...]                             open headed Chromium for Chrome DevTools MCP
  wst doctor                                            diagnostics
  wst migrate                                           one-shot canonical relocation

env:
  WST_PANES=1                                           single-pane layout (default: codex + magit + zsh)
  WST_DEBUG=1                                           print debug output for new/attach
EOF
}

case "${1:-}" in
  clone)   shift; cmd_clone "$@" ;;
  new)     shift; cmd_new "$@" ;;
  attach)  shift; cmd_attach "$@" ;;
  preview) shift; cmd_preview "$@" ;;
  ls)      shift; cmd_ls "$@" ;;
  rm)      shift; cmd_rm "$@" ;;
  gtinit)  shift; cmd_gtinit "$@" ;;
  chrome)  shift; cmd_chrome "$@" ;;
  doctor)  shift; cmd_doctor "$@" ;;
  migrate) shift; cmd_migrate "$@" ;;
  -h|--help|help|"") usage ;;
  *)       usage; exit 1 ;;
esac
